<Window x:Class="WPF_Test_PLC20260124.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Test_PLC20260124"
        mc:Ignorable="d"
                d:DesignHeight="600" d:DesignWidth="800">
    <Window.Resources>
        <Style x:Key="BorderMain" TargetType="Border">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Background="White">
        <Border Style="{StaticResource BorderMain}">
            <UniformGrid Columns="2">
                <GroupBox Header="PLC Communication">
                    <StackPanel>
                        <!-- CONNECTION -->
                        <GroupBox Header="PLC Connection">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="IP Address:"/>
                                <TextBox Grid.Column="1"
                         Text="{Binding IpAddress}"/>

                                <TextBlock Grid.Row="1" Text="Port:"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding Port}"/>
                            </Grid>
                        </GroupBox>

                        <!-- NETWORK -->
                        <GroupBox Header="Network">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Network No:"/>
                                <TextBox Grid.Column="1"
                                Text="{Binding NetworkNo}"/>

                                <TextBlock Grid.Row="1" Text="Station No:"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                Text="{Binding StationNo}"/>
                            </Grid>
                        </GroupBox>

                        <!-- DATA -->
                        <GroupBox Header="Data Area">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Device Type:"/>
                                <ComboBox Grid.Column="1"
                          SelectedItem="{Binding DeviceType}">
                                    <ComboBoxItem Content="D"/>
                                    <ComboBoxItem Content="M"/>
                                    <ComboBoxItem Content="X"/>
                                    <ComboBoxItem Content="Y"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Text="Start Address:"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding StartAddress}"/>

                                <TextBlock Grid.Row="2" Text="Length:"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding Length}"/>
                                <TextBlock Grid.Row="3" Text="Value:"/>
                                <TextBox Grid.Row="3" Grid.Column="1"
                            Text="{Binding ValuePLC}"/>
                            </Grid>
                        </GroupBox>

                        <!-- ACTION -->
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Button Content="Connect"
                    Command="{Binding ConnectCommand}"
                    Width="100"/>

                            <Button Content="Read"
                    Command="{Binding TestReadCommand}"
                    Width="100"
                    Margin="10"/>
                            <Button Content="Write"
                        Command="{Binding TestWriteCommand}"
                        Width="100"
                        Margin="10"/>
                            <Button Content="Write"
                                Command="{Binding TestBit}"
                                Width="100"
                                Margin="10"/>
                        </StackPanel>

                        <!-- STATUS -->
                        <TextBlock Text="{Binding Status}"
                   Foreground="Green"
                   Margin="5"/>

                    </StackPanel>
                </GroupBox>
            </UniformGrid>
        </Border>
    </Grid>
</Window>
