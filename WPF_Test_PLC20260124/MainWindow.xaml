<Window x:Class="WPF_Test_PLC20260124.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Control Panel" Height="450" Width="700">
    <Window.Resources>
        <Style x:Key="BorderMain" TargetType="Border">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="BtnConnectStyle" TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnDisconnectStyle" TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="Text" Value="PLC is Disconnected"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="True">
                    <Setter Property="Foreground" Value="Green"/>
                    <Setter Property="Text" Value="PLC is Connected"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Connection -->
        <Border Style="{StaticResource BorderMain}" Grid.Column="0">
            <StackPanel>
                <GroupBox Header="PLC Connection">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="IP Address:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding IpAddress}" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Text="Port:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Margin="0,2"/>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Content="Connect" Command="{Binding ConnectCommand}" Width="80" Margin="5" Style="{StaticResource BtnConnectStyle}"/>
                            <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Width="80" Margin="5" Style="{StaticResource BtnDisconnectStyle}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <TextBlock Style="{StaticResource StatusTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Right Panel: Data -->
        <TabControl Grid.Column="1" Margin="5">
            <TabItem Header="Machine Control">
                <Border Style="{StaticResource BorderMain}" BorderThickness="0" Margin="0">
                    <StackPanel>
                        <!-- Parameters -->
                        <GroupBox Header="Parameters &amp; Control">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Headers -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Target (Set)" FontWeight="DemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Current (PLC)" FontWeight="DemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Speed:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SetSpeed, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                                <Border Grid.Row="1" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5" Background="#FFEFEFEF">
                                    <TextBlock Text="{Binding CurrentSpeed}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="POS_X:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SetPosX, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                                <Border Grid.Row="2" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5" Background="#FFEFEFEF">
                                    <TextBlock Text="{Binding CurrentPosX}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="POS_Y:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SetPosY, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                                <Border Grid.Row="3" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5" Background="#FFEFEFEF">
                                    <TextBlock Text="{Binding CurrentPosY}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <Button Grid.Row="1" Grid.Column="3" Grid.RowSpan="3" Content="Write Targets" Margin="10" Command="{Binding WriteDataCommand}" FontWeight="Bold"/>
                            </Grid>
                        </GroupBox>

                        <!-- Jog -->
                        <GroupBox Header="Jog / Manual Control (M3000-M3005)">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- X Axis -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="X Axis" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <Button Content="X+ (M3000)" Tag="3000" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                    <Button Content="X- (M3001)" Tag="3001" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                </StackPanel>

                                <!-- Y Axis -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Y Axis" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <Button Content="Y+ (M3002)" Tag="3002" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                    <Button Content="Y- (M3003)" Tag="3003" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                </StackPanel>

                                <!-- Z Axis -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Z Axis" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <Button Content="Z+ (M3004)" Tag="3004" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                    <Button Content="Z- (M3005)" Tag="3005" Width="80" Height="40" Margin="5" PreviewMouseDown="JogBtn_PreviewMouseDown" PreviewMouseUp="JogBtn_PreviewMouseUp" MouseLeave="JogBtn_MouseLeave"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Telemetry">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Read Section -->
                    <GroupBox Header="DATA_READ_BUFFER" Grid.Row="0" Margin="0,0,0,10" BorderBrush="#c2c6d8" FontWeight="SemiBold">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Device Type" FontWeight="Normal" Margin="0,0,0,5"/>
                                <ComboBox SelectedItem="{Binding TelemetryReadDeviceTypeStr}" Width="80" Height="25">
                                    <ComboBoxItem Content="D"/>
                                    <ComboBoxItem Content="M"/>
                                    <ComboBoxItem Content="X"/>
                                    <ComboBoxItem Content="Y"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                <TextBlock Text="PLC_ADDRESS" FontWeight="Normal" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding TelemetryReadAddress, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="25" Padding="4" BorderBrush="#c2c6d8"/>
                            </StackPanel>
                            
                            <!-- Display Area -->
                            <Border Grid.Column="2" Background="#eff4ff" BorderBrush="#0050cb" BorderThickness="1" Padding="10" MinHeight="60">
                                <TextBlock Text="{Binding TelemetryReadValue}" FontSize="28" FontWeight="Bold" FontFamily="Consolas" Foreground="#001849" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </GroupBox>
                    
                    <!-- Write Section -->
                    <GroupBox Header="DATA_WRITE_COMMAND" Grid.Row="1" BorderBrush="#c2c6d8" FontWeight="SemiBold">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Device Type" FontWeight="Normal" Margin="0,0,0,5"/>
                                    <ComboBox SelectedItem="{Binding TelemetryWriteDeviceTypeStr}" Width="80" Height="25">
                                        <ComboBoxItem Content="D"/>
                                        <ComboBoxItem Content="M"/>
                                        <ComboBoxItem Content="X"/>
                                        <ComboBoxItem Content="Y"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="TARGET_ADDRESS" FontWeight="Normal" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TelemetryWriteAddress, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="25" Padding="4" BorderBrush="#c2c6d8"/>
                                </StackPanel>
                                
                                <StackPanel>
                                    <TextBlock Text="SET_VALUE" FontWeight="Normal" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TelemetryWriteValue, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="25" Padding="4" BorderBrush="#c2c6d8"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Grid.Row="1" Content="WRITE_COMMIT" Command="{Binding WriteTelemetryCommand}" Background="#0050cb" Foreground="White" FontWeight="Bold" Width="150" Height="35" HorizontalAlignment="Left" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
