@page "/telemetry"
@inject WPF_Test_PLC20260124.MainViewModel ViewModel
@using System.Timers

<style>
    @@keyframes value-flash {
        0%   { background-color: rgba(0, 200, 83, 0.25); }
        50%  { background-color: rgba(0, 200, 83, 0.15); }
        100% { background-color: transparent; }
    }
    .value-updated {
        animation: value-flash 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(0.7); }
    }
    .live-dot { animation: pulse-dot 1.4s ease-in-out infinite; }
</style>

<div class="space-y-8">

    <!-- ═══════════════════════════════════════════════════════════
         TOP ROW: Read Monitor (40%) + Write Control (60%)
    ═══════════════════════════════════════════════════════════ -->
    <div class="grid grid-cols-12 gap-6">

        <!-- ── LEFT: REAL-TIME MONITOR ─────────────────────────── -->
        <section class="col-span-12 lg:col-span-5 bg-surface-container-low rounded-lg p-6 space-y-5">

            <!-- Header -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-secondary live-dot"></span>
                    <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant">
                        Real-Time Monitor
                    </h2>
                </div>
                <div class="flex items-center gap-3">
                    <button @onclick="ToggleAutoRefresh"
                            class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider transition-all
                                   @(autoRefresh ? "bg-secondary-container text-on-secondary-container" : "bg-surface-container-highest text-outline")">
                        <span class="w-1.5 h-1.5 rounded-full @(autoRefresh ? "bg-secondary" : "bg-outline")"></span>
                        @(autoRefresh ? "Auto ON" : "Auto OFF")
                    </button>
                </div>
            </div>

            <!-- Address Entry List -->
            <div class="space-y-3">
                @foreach (var entry in readEntries)
                {
                    <div class="relative bg-surface-container-lowest rounded-lg flex items-center gap-0 overflow-hidden shadow-sm
                                @(entry.JustUpdated ? "value-updated" : "") transition-colors group">
                        <!-- Accent Bar -->
                        <div class="w-1 self-stretch" style="background-color: @GetTypeColor(entry.AddrType);"></div>

                        <div class="flex-1 flex items-center justify-between px-4 py-3">
                            <div class="flex items-center gap-3">
                                <!-- Address Type Badge -->
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase font-label tracking-wider text-white"
                                      style="background-color: @GetTypeColor(entry.AddrType);">
                                    @entry.AddrType
                                </span>
                                <!-- Address Index -->
                                <span class="font-mono text-sm font-bold text-on-surface">
                                    @FormatAddress(entry.AddrType, entry.AddrIndex, entry.AddrIndexText)
                                </span>
                            </div>
                            <div class="text-right">
                                <div class="font-headline text-2xl font-bold text-on-surface">@entry.Value</div>
                                <div class="text-[10px] font-body text-outline">upd @entry.UpdatedMs ms ago</div>
                            </div>
                        </div>

                        <!-- Remove button -->
                        <button @onclick="() => RemoveReadEntry(entry)"
                                class="mr-2 p-1 text-outline hover:text-tertiary transition-colors opacity-0 group-hover:opacity-100">
                            <span class="material-symbols-outlined text-sm">close</span>
                        </button>
                    </div>
                }
            </div>

            <!-- Add Address Row -->
            @if (showAddRead)
            {
                <div class="flex gap-2 bg-surface-container-lowest rounded-lg p-3 shadow-sm">
                    <select @bind="newReadType"
                            class="bg-surface-container-highest text-on-surface font-label text-xs font-bold uppercase rounded px-2 py-2 focus:outline-none focus:ring-2 focus:ring-primary/30">
                        <option>D</option><option>M</option><option>X</option><option>Y</option><option>U0G</option>
                    </select>
                    <input type="text" @bind="newReadIndexText" placeholder="Address (dec or hex)"
                           class="flex-1 bg-surface-container-highest text-on-surface font-mono text-sm px-3 py-2 rounded focus:outline-none focus:ring-2 focus:ring-primary/30" />
                    <button @onclick="AddReadEntry"
                            class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-4 py-2 rounded font-label text-xs font-bold uppercase">
                        Add
                    </button>
                    <button @onclick="() => showAddRead = false"
                            class="text-outline hover:text-on-surface px-2 py-2">
                        <span class="material-symbols-outlined text-sm">close</span>
                    </button>
                </div>
            }

            <div class="flex gap-3 pt-1">
                <button @onclick="() => showAddRead = true"
                        class="flex items-center gap-1 border border-outline-variant/40 text-primary font-label text-xs font-bold uppercase tracking-wider px-4 py-2 rounded hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">add</span> Add Address
                </button>
                <button @onclick="ManualRefresh"
                        class="flex items-center gap-1 border border-outline-variant/40 text-on-surface-variant font-label text-xs font-bold uppercase tracking-wider px-4 py-2 rounded hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">refresh</span> Refresh All
                </button>
            </div>
        </section>

        <!-- ── RIGHT: WRITE CONTROL ────────────────────────────── -->
        <section class="col-span-12 lg:col-span-7 bg-surface-container-low rounded-lg p-6 space-y-5">

            <!-- Header -->
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base text-tertiary">warning</span>
                <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant">
                    Write Control
                </h2>
            </div>

            <!-- Write Entry List -->
            <div class="space-y-3">
                @foreach (var entry in writeEntries)
                {
                    <div class="bg-surface-container-lowest rounded-lg p-4 shadow-sm group">
                        <div class="flex items-center gap-3">
                            <!-- Type Selector -->
                            <select @bind="entry.AddrType"
                                    class="bg-surface-container-highest text-on-surface font-label text-xs font-bold uppercase rounded px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 w-20">
                                <option>D</option><option>M</option><option>X</option><option>Y</option><option>U0G</option>
                            </select>

                            <!-- Address Index -->
                            <div class="flex-shrink-0 w-28">
                                <input type="text" @bind="entry.AddrIndexText" @bind:event="oninput" placeholder="Address"
                                       class="w-full bg-surface-container-highest text-on-surface font-mono text-sm px-3 py-2.5 rounded focus:outline-none focus:ring-2 focus:ring-primary/30" />
                            </div>

                            <!-- Value Input -->
                            <div class="flex-1">
                                                <input type="number" @bind="entry.WriteValue" placeholder="Value (-2147483648..2147483647 for D32)"
                                       class="w-full bg-surface-container-highest text-on-surface font-mono text-sm px-3 py-2.5 rounded focus:outline-none focus:ring-2 focus:ring-primary/30" />
                            </div>

                            <!-- Write Button -->
                            <button @onclick="() => ExecuteWrite(entry)"
                                    class="flex items-center gap-1.5 bg-gradient-to-r from-primary to-primary-container text-on-primary font-label text-xs font-bold uppercase px-4 py-2.5 rounded hover:brightness-110 transition-all">
                                <span class="material-symbols-outlined text-sm">upload</span>
                                Write
                            </button>

                            <!-- Status Chip -->
                            @if (entry.Status == WriteStatus.OK)
                            {
                                <span class="flex items-center gap-1 px-2 py-1 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold font-label uppercase whitespace-nowrap">
                                    <span class="material-symbols-outlined text-xs">check_circle</span> OK
                                </span>
                            }
                            else if (entry.Status == WriteStatus.ERR)
                            {
                                <span class="flex items-center gap-1 px-2 py-1 bg-error-container text-on-error-container rounded-full text-[10px] font-bold font-label uppercase whitespace-nowrap">
                                    <span class="material-symbols-outlined text-xs">cancel</span> ERR
                                </span>
                            }
                            else
                            {
                                <span class="w-14 h-6"></span>
                            }

                            <!-- Remove -->
                            <button @onclick="() => RemoveWriteEntry(entry)"
                                    class="text-outline hover:text-tertiary transition-colors opacity-0 group-hover:opacity-100 ml-1">
                                <span class="material-symbols-outlined text-sm">delete_outline</span>
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(entry.ErrorMessage))
                        {
                            <p class="mt-2 text-xs font-body text-tertiary pl-1">⚠ @entry.ErrorMessage</p>
                        }
                    </div>
                }
            </div>

            <button @onclick="AddWriteEntry"
                    class="flex items-center gap-1 border border-outline-variant/40 text-primary font-label text-xs font-bold uppercase tracking-wider px-4 py-2 rounded hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-sm">add</span> Add Write Entry
            </button>
        </section>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM: ACTION HISTORY LOG
    ═══════════════════════════════════════════════════════════ -->
    <section class="bg-surface-container-lowest rounded-lg overflow-hidden shadow-sm">

        <!-- Log Header -->
        <div class="px-6 py-4 flex justify-between items-center bg-surface-container-low">
            <div class="flex items-center gap-3">
                <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant">
                    Action History
                </h2>
                <span class="bg-primary text-on-primary text-[10px] font-bold font-label px-2 py-0.5 rounded-full">
                    @actionLog.Count
                </span>
            </div>
            <button @onclick="ClearLog"
                    class="flex items-center gap-1 text-outline hover:text-tertiary font-label text-xs uppercase tracking-wider transition-colors">
                <span class="material-symbols-outlined text-sm">delete_sweep</span> Clear Log
            </button>
        </div>

        <!-- Log Table -->
        <div class="bg-inverse-surface overflow-y-auto max-h-64 relative">
            <!-- Fade gradients -->
            <div class="sticky top-0 h-6 bg-gradient-to-b from-inverse-surface to-transparent pointer-events-none z-10"></div>

            @if (actionLog.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-12 text-outline gap-2">
                    <span class="material-symbols-outlined text-3xl">terminal</span>
                    <span class="font-label text-xs uppercase tracking-widest">No actions yet...</span>
                </div>
            }
            else
            {
                <table class="w-full text-xs font-mono">
                    <thead>
                        <tr class="text-outline-variant/60 font-label uppercase tracking-wider text-[10px]">
                            <th class="px-5 py-2 text-left">Timestamp</th>
                            <th class="px-3 py-2 text-left">Type</th>
                            <th class="px-3 py-2 text-left">Address</th>
                            <th class="px-3 py-2 text-right">Value</th>
                            <th class="px-5 py-2 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in actionLog.AsEnumerable().Reverse().Take(50))
                        {
                            <tr class="border-t border-inverse-on-surface/10 hover:bg-inverse-on-surface/10 transition-colors">
                                <td class="px-5 py-2 text-outline-variant whitespace-nowrap">@log.Timestamp.ToString("HH:mm:ss.fff")</td>
                                <td class="px-3 py-2">
                                    @if (log.Type == "READ")
                                    {
                                        <span class="px-2 py-0.5 rounded border border-primary-fixed-dim text-primary-fixed-dim font-label font-bold text-[10px] uppercase">READ</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-0.5 rounded bg-amber-500/20 text-amber-400 font-label font-bold text-[10px] uppercase">WRITE</span>
                                    }
                                </td>
                                <td class="px-3 py-2 font-bold text-inverse-on-surface">@log.Address</td>
                                <td class="px-3 py-2 text-right text-primary-fixed-dim font-bold">@log.Value</td>
                                <td class="px-5 py-2 text-center">
                                    @if (log.Success)
                                    {
                                        <span class="material-symbols-outlined text-secondary-fixed-dim text-sm">check_circle</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-tertiary-fixed-dim text-sm">cancel</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="sticky bottom-0 h-6 bg-gradient-to-t from-inverse-surface to-transparent pointer-events-none z-10"></div>
        </div>
    </section>

</div>

@code {
    // ─── Models ────────────────────────────────────────────────────
    public class ReadEntry
    {
        public string AddrType { get; set; } = "D";
        public int AddrIndex { get; set; }
        public string AddrIndexText { get; set; } = "";
        public int Value { get; set; }
        public long UpdatedMs { get; set; }
        public bool JustUpdated { get; set; }
        public int PrevValue { get; set; }
    }

    public enum WriteStatus { None, OK, ERR }
    public class PlcWriteItem
    {
        public string AddrType { get; set; } = "D";
        public int AddrIndex { get; set; }
        public string AddrIndexText { get; set; } = "";
        public int WriteValue { get; set; }
        public WriteStatus Status { get; set; } = WriteStatus.None;
        public string ErrorMessage { get; set; } = "";
    }

    public class LogEntry
    {
        public DateTime Timestamp { get; set; }
        public string Type { get; set; } = "";
        public string Address { get; set; } = "";
        public int Value { get; set; }
        public bool Success { get; set; }
    }

    // ─── State ─────────────────────────────────────────────────────
    static List<ReadEntry> _persistedReadEntries = new()
    {
        new() { AddrType = "D", AddrIndex = 4000, AddrIndexText = "4000" },
        new() { AddrType = "D", AddrIndex = 4001, AddrIndexText = "4001" },
        new() { AddrType = "D", AddrIndex = 4002, AddrIndexText = "4002" },
        new() { AddrType = "M", AddrIndex = 0, AddrIndexText = "0" },
    };

    List<ReadEntry> readEntries => _persistedReadEntries;

    static List<PlcWriteItem> _persistedWriteEntries = new()
    {
        new() { AddrType = "D", AddrIndex = 5000, AddrIndexText = "5000" },
        new() { AddrType = "D", AddrIndex = 5001, AddrIndexText = "5001" },
        new() { AddrType = "M", AddrIndex = 0, AddrIndexText = "0" },
    };

    List<PlcWriteItem> writeEntries => _persistedWriteEntries;

    static List<LogEntry> _persistedActionLog = new();
    List<LogEntry> actionLog => _persistedActionLog;

    static bool _persistedAutoRefresh = true;
    bool autoRefresh
    {
        get => _persistedAutoRefresh;
        set => _persistedAutoRefresh = value;
    }

    bool showAddRead = false;
    string newReadType = "D";
    string newReadIndexText = "";

    System.Timers.Timer? _timer;
    bool _isRefreshingRead = false;

    // ─── Lifecycle ─────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        ViewModel.AddLog("UI", "info", "Telemetry page loaded");
        foreach (var entry in readEntries)
            EnsureEntryAddressText(entry);
        foreach (var entry in writeEntries)
            EnsureEntryAddressText(entry);
        SyncAllReadEntriesToCustomMemory();
        ViewModel.PropertyChanged += OnViewModelChanged;
        _timer = new System.Timers.Timer(250);
        _timer.Elapsed += OnTimerTick;
        _timer.AutoReset = true;
        _timer.Start();
    }

    void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        // Avoid high-frequency read jitter: polling is handled by timer only.
        if (e.PropertyName == nameof(ViewModel.Status))
        {
            InvokeAsync(StateHasChanged);
        }
    }

    async void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        if (!autoRefresh || _isRefreshingRead)
            return;

        _isRefreshingRead = true;
        try
        {
            await InvokeAsync(() =>
            {
                UpdateReadValues();
                StateHasChanged();
            });
        }
        finally
        {
            _isRefreshingRead = false;
        }
    }

    // ─── Read Logic ────────────────────────────────────────────────
    void UpdateReadValues()
    {
        if (!ViewModel.Status) return;

        foreach (var entry in readEntries)
        {
            int newVal = 0;
            bool found = false;

            var custom = FindCustomEntry(entry);

            if (custom != null)
            {
                newVal = custom.CurrentValue;
                found = true;
            }

            if (!found && entry.AddrType == "D" && ViewModel.arr_R_V != null)
            {
                int offset = entry.AddrIndex - ViewModel.D_R_V;
                if (offset >= 0 && offset < ViewModel.arr_R_V.Length)
                {
                    newVal = ViewModel.arr_R_V[offset];
                    found = true;
                }
            }
            else if (!found && entry.AddrType == "M" && ViewModel.arr_R_M != null)
            {
                int offset = entry.AddrIndex - ViewModel.M_R_Base;
                if (offset >= 0 && offset < ViewModel.arr_R_M.Length)
                {
                    newVal = ViewModel.arr_R_M[offset];
                    found = true;
                }
            }
            else if (!found && entry.AddrType == "X" && ViewModel.arr_R_X != null)
            {
                int offset = entry.AddrIndex - ViewModel.X_R_Base;
                if (offset >= 0 && offset < ViewModel.arr_R_X.Length)
                {
                    newVal = ViewModel.arr_R_X[offset];
                    found = true;
                }
            }
            else if (!found && entry.AddrType == "Y" && ViewModel.arr_R_Y != null)
            {
                int offset = entry.AddrIndex - ViewModel.Y_R_Base;
                if (offset >= 0 && offset < ViewModel.arr_R_Y.Length)
                {
                    newVal = ViewModel.arr_R_Y[offset];
                    found = true;
                }
            }

            if (found && newVal != entry.PrevValue)
            {
                entry.PrevValue = newVal;
                entry.Value = newVal;
                entry.JustUpdated = true;
                entry.UpdatedMs = 0;
                AddLog("READ", FormatAddress(entry.AddrType, entry.AddrIndex, entry.AddrIndexText), newVal, true);
                
                // Trigger animation, then reset JustUpdated flag after 800ms (animation duration)
                _ = Task.Delay(800).ContinueWith(_ =>
                {
                    InvokeAsync(() =>
                    {
                        entry.JustUpdated = false;
                        StateHasChanged();
                    });
                });
            }
            else if (found)
            {
                entry.JustUpdated = false;
            }
        }
    }

    void ManualRefresh()
    {
        if (_isRefreshingRead)
            return;

        _isRefreshingRead = true;

        // Mark all entries for flash animation
        foreach (var entry in readEntries)
        {
            entry.JustUpdated = true;
            
            // Reset JustUpdated flag after animation
            _ = Task.Delay(800).ContinueWith(_ =>
            {
                InvokeAsync(() =>
                {
                    entry.JustUpdated = false;
                    StateHasChanged();
                });
            });
        }
        
        UpdateReadValues();
        StateHasChanged();

        _isRefreshingRead = false;
    }

    void ToggleAutoRefresh()
    {
        autoRefresh = !autoRefresh;
    }

    void AddReadEntry()
    {
        string normalizedType = NormalizeType(newReadType);
        if (!TryParseAddressIndex(normalizedType, newReadIndexText, out int parsedIndex, out string parsedText))
        {
            ViewModel.AddLog("UI", "warning", $"Invalid address: {newReadType}{newReadIndexText}");
            return;
        }

        bool exists = readEntries.Any(x =>
            x.AddrType == normalizedType
            && x.AddrIndex == parsedIndex
            && (IsBufferType(normalizedType)
                ? string.Equals(x.AddrIndexText, parsedText, StringComparison.OrdinalIgnoreCase)
                : true));
        if (!exists)
        {
            readEntries.Add(new ReadEntry { AddrType = normalizedType, AddrIndex = parsedIndex, AddrIndexText = parsedText });
            string storageText = IsBufferType(normalizedType) ? parsedText : string.Empty;
            ViewModel.AddCustomMemoryEntry(normalizedType, parsedIndex, storageText);
            ViewModel.AddLog("UI", "info", $"Telemetry read entry added: {FormatAddress(normalizedType, parsedIndex, parsedText)}");
        }

        showAddRead = false;
        newReadIndexText = "";
    }

    void RemoveReadEntry(ReadEntry e)
    {
        readEntries.Remove(e);

        var custom = ViewModel.CustomMemoryEntries.FirstOrDefault(x =>
            x.AddrType.Equals(e.AddrType, StringComparison.OrdinalIgnoreCase)
            && x.AddrIndex == e.AddrIndex
            && (IsBufferType(e.AddrType)
                ? string.Equals(x.AddrIndexText ?? string.Empty, e.AddrIndexText ?? string.Empty, StringComparison.OrdinalIgnoreCase)
                : true));
        if (custom != null)
            ViewModel.RemoveCustomMemoryEntry(custom);

        ViewModel.AddLog("UI", "info", $"Telemetry read entry removed: {FormatAddress(e.AddrType, e.AddrIndex, e.AddrIndexText)}");
    }

    void SyncAllReadEntriesToCustomMemory()
    {
        foreach (var entry in readEntries)
        {
            string storageText = IsBufferType(entry.AddrType) ? entry.AddrIndexText : string.Empty;
            ViewModel.AddCustomMemoryEntry(entry.AddrType, entry.AddrIndex, storageText);
        }
    }

    // ─── Write Logic ───────────────────────────────────────────────
    void ExecuteWrite(PlcWriteItem entry)
    {
        entry.ErrorMessage = "";

        // Validate based on address type
        if (entry.AddrType == "D")
        {
            // D writes are packed as 32-bit into Dn (low) + Dn+1 (high).
            // entry.WriteValue is int, already constrained to Int32 range by type.
        }
        else if (entry.AddrType == "M" || entry.AddrType == "X" || entry.AddrType == "Y")
        {
            // M, X, Y are bit devices: only 0 or 1
            if (entry.WriteValue != 0 && entry.WriteValue != 1)
            {
                entry.Status = WriteStatus.ERR;
                entry.ErrorMessage = $"{entry.AddrType} register is a BIT device - value must be 0 or 1 only.";
                AddLog("WRITE", FormatAddress(entry.AddrType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, false);
                return;
            }
        }

        if (!ViewModel.Status)
        {
            entry.Status = WriteStatus.ERR;
            entry.ErrorMessage = "PLC not connected.";
            AddLog("WRITE", FormatAddress(entry.AddrType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, false);
            return;
        }

        try
        {
            string normType = NormalizeType(entry.AddrType);
            if (!TryParseAddressIndex(normType, entry.AddrIndexText, out int parsedIndex, out string parsedText))
            {
                entry.Status = WriteStatus.ERR;
                entry.ErrorMessage = "Invalid address format.";
                AddLog("WRITE", FormatAddress(normType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, false);
                return;
            }

            entry.AddrIndex = parsedIndex;
            entry.AddrIndexText = parsedText;

            if (normType == "D" || normType == "M" || normType == "X" || normType == "Y" || IsBufferType(normType))
            {
                // Keep mirror buffers in sync when address is inside configured ranges.
                if (normType == "D")
                {
                    int lowWord = entry.WriteValue & 0xFFFF;
                    int highWord = (entry.WriteValue >> 16) & 0xFFFF;

                    int offsetP = entry.AddrIndex - ViewModel.D_W_P;
                    if (offsetP >= 0 && (offsetP + 1) < ViewModel.arr_W_P.Length)
                    {
                        ViewModel.arr_W_P[offsetP] = lowWord;
                        ViewModel.arr_W_P[offsetP + 1] = highWord;
                    }

                    int offsetV = entry.AddrIndex - ViewModel.D_W_V;
                    if (offsetV >= 0 && (offsetV + 1) < ViewModel.arr_W_V.Length)
                    {
                        ViewModel.arr_W_V[offsetV] = lowWord;
                        ViewModel.arr_W_V[offsetV + 1] = highWord;
                    }
                }
                else if (normType == "M")
                {
                    int offsetM = entry.AddrIndex - ViewModel.M_W_Base;
                    if (offsetM >= 0 && offsetM < ViewModel.arr_W_M.Length)
                        ViewModel.arr_W_M[offsetM] = entry.WriteValue;
                }
                else if (normType == "X")
                {
                    int offsetX = entry.AddrIndex - ViewModel.X_W_Base;
                    if (offsetX >= 0 && offsetX < ViewModel.arr_W_X.Length)
                        ViewModel.arr_W_X[offsetX] = entry.WriteValue;
                }
                else if (normType == "Y")
                {
                    int offsetY = entry.AddrIndex - ViewModel.Y_W_Base;
                    if (offsetY >= 0 && offsetY < ViewModel.arr_W_Y.Length)
                        ViewModel.arr_W_Y[offsetY] = entry.WriteValue;
                }

                string addrText = IsBufferType(normType) ? entry.AddrIndexText : string.Empty;
                ViewModel.MarkPendingWrite(normType, entry.AddrIndex, entry.WriteValue, addrText);
                entry.Status = WriteStatus.OK;
                AddLog("WRITE", FormatAddress(normType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, true);
            }
            else
            {
                entry.Status = WriteStatus.ERR;
                entry.ErrorMessage = $"Unknown address type: {normType}.";
                AddLog("WRITE", FormatAddress(normType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, false);
            }
        }
        catch (Exception ex)
        {
            entry.Status = WriteStatus.ERR;
            entry.ErrorMessage = ex.Message;
            AddLog("WRITE", FormatAddress(entry.AddrType, entry.AddrIndex, entry.AddrIndexText), entry.WriteValue, false);
        }
    }

    void AddWriteEntry() => writeEntries.Add(new PlcWriteItem { AddrIndexText = "0" });
    void RemoveWriteEntry(PlcWriteItem e) => writeEntries.Remove(e);

    // ─── Log ───────────────────────────────────────────────────────
    void AddLog(string type, string addr, int value, bool success)
    {
        actionLog.Add(new LogEntry
        {
            Timestamp = DateTime.Now,
            Type = type,
            Address = addr,
            Value = value,
            Success = success,
        });
        // Keep max 200 entries
        if (actionLog.Count > 200) actionLog.RemoveAt(0);
    }

    void ClearLog() => actionLog.Clear();

    // ─── Helpers ───────────────────────────────────────────────────
    string GetTypeColor(string type) => type switch
    {
        "D" => "#0050cb",
        "M" => "#006c49",
        "X" => "#b45309",
        "Y" => "#7c3aed",
        _   => "#2a9d8f"
    };

    string NormalizeType(string? addrType)
    {
        string t = string.IsNullOrWhiteSpace(addrType) ? "D" : addrType.Trim().ToUpperInvariant();
        return t;
    }

    bool IsBufferType(string addrType)
    {
        return addrType.StartsWith("U", StringComparison.OrdinalIgnoreCase);
    }

    bool TryParseAddressIndex(string addrType, string input, out int index, out string normalizedText)
    {
        normalizedText = "";
        index = 0;

        string raw = input?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(raw))
            raw = "0";

        if (IsBufferType(addrType))
        {
            if (int.TryParse(raw, System.Globalization.NumberStyles.HexNumber, null, out int hexValue))
            {
                index = hexValue;
                normalizedText = raw.ToUpperInvariant();
                return true;
            }

            return false;
        }

        if (int.TryParse(raw, out int decValue))
        {
            index = decValue;
            normalizedText = decValue.ToString();
            return true;
        }

        return false;
    }

    void EnsureEntryAddressText(ReadEntry entry)
    {
        if (!string.IsNullOrWhiteSpace(entry.AddrIndexText))
            return;

        if (IsBufferType(entry.AddrType))
            entry.AddrIndexText = entry.AddrIndex.ToString("X");
        else
            entry.AddrIndexText = entry.AddrIndex.ToString();
    }

    void EnsureEntryAddressText(PlcWriteItem entry)
    {
        if (!string.IsNullOrWhiteSpace(entry.AddrIndexText))
            return;

        if (IsBufferType(entry.AddrType))
            entry.AddrIndexText = entry.AddrIndex.ToString("X");
        else
            entry.AddrIndexText = entry.AddrIndex.ToString();
    }

    string FormatAddress(string addrType, int addrIndex, string? addrIndexText)
    {
        string t = NormalizeType(addrType);
        if (IsBufferType(t))
        {
            string prefix = t.Replace("\\", string.Empty).Replace("/", string.Empty);
            if (!prefix.Contains("G", StringComparison.OrdinalIgnoreCase))
                prefix += "G";
            string indexText = string.IsNullOrWhiteSpace(addrIndexText) ? addrIndex.ToString("X") : addrIndexText.Trim().ToUpperInvariant();
            return prefix + indexText;
        }

        return $"{t}{addrIndex}";
    }

    MainViewModel.CustomMemoryEntry? FindCustomEntry(ReadEntry entry)
    {
        return ViewModel.CustomMemoryEntries.FirstOrDefault(x =>
            x.AddrType.Equals(entry.AddrType, StringComparison.OrdinalIgnoreCase)
            && x.AddrIndex == entry.AddrIndex
            && (IsBufferType(entry.AddrType)
                ? string.Equals(x.AddrIndexText ?? string.Empty, entry.AddrIndexText ?? string.Empty, StringComparison.OrdinalIgnoreCase)
                : true));
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
        ViewModel.PropertyChanged -= OnViewModelChanged;
    }
}
