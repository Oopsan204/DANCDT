    .settings-nav-item:hover { background: var(--c-surface-container); }
    .settings-nav-item.active { background: var(--c-surface-container-lowest); color: var(--c-primary); border-left: 3px solid var(--c-primary); }
    .nav-active-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--c-primary); margin-left: auto; }
    .settings-sidebar-footer { margin-top: auto; padding: 12px 16px; border-top: 1px solid var(--c-outline-variant); }
