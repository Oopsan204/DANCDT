    .addr-input { width: 100%; max-width: 100px; padding: 6px 10px; border: 1px solid var(--c-outline-variant); border-radius: 4px; background: var(--c-surface-container-low); color: var(--c-on-surface); font-family: 'Roboto Mono', monospace; font-size: 12px; transition: 0.2s; }
    .addr-input:focus { border-color: var(--c-primary); outline: none; box-shadow: 0 0 0 2px var(--c-primary-container); }
