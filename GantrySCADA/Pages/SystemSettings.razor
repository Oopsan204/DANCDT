    .settings-header-icon { font-size: 22px; color: var(--c-primary); background: var(--c-surface-container-high); border-radius: 6px; padding: 4px; }
    .settings-header-title { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; color: var(--c-on-surface); }
