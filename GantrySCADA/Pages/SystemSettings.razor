                    </h2>
                    <p class="section-subtitle">TCP/IP network configuration for Mitsubishi PLC</p>
                </div>
            </div>

            <div class="settings-card">
                <div class="card-header accent-blue">
                    <span class="material-symbols-outlined">lan</span>
                    <div>
                        <h3 class="card-title">Network Parameters</h3>
                        <p class="card-subtitle">IP and Port settings for external communication</p>
                    </div>
                </div>
                <div class="card-body">
                    <div class="scaling-grid">
                        <div class="scaling-group">
                            <label class="scale-label">IP Address</label>
                            <input class="addr-input" type="text" @bind="ViewModel.IpAddress" />
                        </div>
                        <div class="scaling-group">
                            <label class="scale-label">Port</label>
                            <input class="addr-input" type="number" @bind="ViewModel.Port" />
                        </div>
                        <div class="scaling-group">
                            <label class="scale-label">Station No</label>
                            <input class="addr-input" type="number" @bind="ViewModel.StationNo" />
                        </div>
                    </div>

                    <div class="conn-status-row">
                        <div class="conn-indicator @(ViewModel.Status ? "conn-ok" : "conn-err")">
                            <span class="conn-dot"></span>
                            @(ViewModel.Status ? "CONNECTED" : "DISCONNECTED")
                        </div>
                        @if (!ViewModel.Status)
                        {
                            <button class="btn-primary" @onclick="() => ViewModel.ConnectCommand.Execute(null)">
                                <span class="material-symbols-outlined">link</span> Connect
                            </button>
                        }
                        else
                        {
                            <button class="btn-ghost" @onclick="() => ViewModel.DisconnectCommand.Execute(null)">
                                <span class="material-symbols-outlined">link_off</span> Disconnect
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (activeSection == "general")
        {
            <div class="section-header">
                <div>
                    <h2 class="section-title"><span class="material-symbols-outlined">tune</span> General Config</h2>
                    <p class="section-subtitle">Monitor polling parameters and logging settings</p>
