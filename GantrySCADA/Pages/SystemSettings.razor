@page "/settings"
@inject WPF_Test_PLC20260124.MainViewModel ViewModel
@inject IJSRuntime JS

<div class="settings-page">

    <!-- ── LEFT SIDEBAR ─────────────────────────────────────────── -->
    <aside class="settings-sidebar">
        <div class="settings-sidebar-header">
            <span class="material-symbols-outlined settings-header-icon">settings</span>
            <div>
                <p class="settings-header-title">System Settings</p>
                <p class="settings-header-sub">GantrySCADA v1.0</p>
            </div>
        </div>

        <nav class="settings-nav">
            @foreach (var item in _navItems)
            {
                <button class="settings-nav-item @(activeSection == item.Key ? "active" : "")"
                        @onclick="() => activeSection = item.Key">
                    <span class="material-symbols-outlined">@item.Icon</span>
                    <span>@item.Label</span>
                    @if (activeSection == item.Key)
                    {
                        <span class="nav-active-dot"></span>
                    }
                </button>
            }
        </nav>

        <div class="settings-sidebar-footer">
            <div class="version-badge">
                <span class="material-symbols-outlined" style="font-size:13px;">memory</span>
                PLC: @(ViewModel.Status ? "CONNECTED" : "OFFLINE")
                <span class="@(ViewModel.Status ? "dot-green" : "dot-red")"></span>
            </div>
        </div>
    </aside>

    <!-- ── MAIN CONTENT ──────────────────────────────────────────── -->
    <div class="settings-content">

        <!-- ══════════════════════════════════════════════════════════
             SECTION: JOB CONFIGURATION
             ══════════════════════════════════════════════════════════ -->
        @if (activeSection == "job")
        {
            <div class="section-header">
                <div>
                    <h2 class="section-title">
                        <span class="material-symbols-outlined">build</span>
                        Job Configuration
                    </h2>
                    <p class="section-subtitle">Configure PLC register addresses and base values for data acquisition</p>
                </div>
                <div class="section-header-actions">
                    <button class="btn-ghost" @onclick="ResetJobDefaults">
                        <span class="material-symbols-outlined">restart_alt</span>
                        Reset Defaults
                    </button>
                </div>
            </div>

            <div class="settings-card">
                <div class="card-header accent-blue">
                    <span class="material-symbols-outlined">map</span>
                    <div>
                        <h3 class="card-title">Job Address Mapping</h3>
                        <p class="card-subtitle">Base D-register addresses used for system telemetry</p>
                    </div>
                </div>
                <div class="card-body">
                    <table class="config-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Addr Type</th>
                                <th>Address Index</th>
                                <th>Current Value</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">D_R_V</span>
                                    Read Velocity Base
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.D_R_V" />
                                </td>
                                <td class="mono-val">@ViewModel.D_R_V</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">D_W_V</span>
                                    Write Velocity Base
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.D_W_V" />
                                </td>
                                <td class="mono-val">@ViewModel.D_W_V</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">V_SLIDER_D</span>
                                    Velocity Slider Write Address
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.VelocityWriteAddress" />
                                </td>
                                <td class="mono-val">@ViewModel.VelocityWriteAddress</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">V_SCALE</span>
                                    Velocity Scale (m/s to raw)
                                </td>
                                <td><span class="addr-badge badge-D">x</span></td>
                                <td>
                                    <input class="addr-input" type="number" step="0.1" min="0.1" max="1000" @bind="ViewModel.VelocityWriteScale" />
                                </td>
                                <td class="mono-val">@ViewModel.VelocityWriteScale</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">D_W_P</span>
                                    Write Position Base
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.D_W_P" />
                                </td>
                                <td class="mono-val">@ViewModel.D_W_P</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">DReadEnable</span>
                                    Read Enable Flag
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.DReadEnable" />
                                </td>
                                <td class="mono-val">@ViewModel.DReadEnable</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">D32Base1</span>
                                    32-bit Block 1 Base
                                </td>
                                <td><span class="addr-badge badge-D">D</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.D32Base1" />
                                </td>
                                <td class="mono-val">@ViewModel.D32Base1</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                            <tr>
                                <td class="param-name">
                                    <span class="code-chip">M_W_Base</span>
                                    Jog Control Base
                                </td>
                                <td><span class="addr-badge badge-M">M</span></td>
                                <td>
                                    <input class="addr-input" type="number" min="0" max="9999" @bind="ViewModel.M_W_Base" />
                                </td>
                                <td class="mono-val">@ViewModel.M_W_Base</td>
                                <td><span class="status-ok material-symbols-outlined">check_circle</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Card 2: Jog Control Mark Addresses -->
            <div class="settings-card">
                <div class="card-header accent-amber">
                    <span class="material-symbols-outlined">sports_esports</span>
                    <div>
                        <h3 class="card-title">Jog Control Mark Addresses</h3>
                        <p class="card-subtitle">M-register bit addresses for manual jog commands</p>
                    </div>
                </div>
                <div class="card-body">
                    <div class="info-box">
                        <span class="material-symbols-outlined">info</span>
                        These M-register addresses map to directional controls on the Dashboard.
                    </div>
                    <table class="config-table">
                        <thead>
                            <tr>
                                <th>Axis</th>
                                <th>Direction</th>
                                <th>Mark Address</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="axis-badge axis-x">X</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_forward</span> + (Right)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogXPosAddress" /></td>
                                <td class="desc-cell">Positive X Jog</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">X</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_back</span> - (Left)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogXNegAddress" /></td>
                                <td class="desc-cell">Negative X Jog</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">Y</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_downward</span> + (Down)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogYPosAddress" /></td>
                                <td class="desc-cell">Positive Y Jog</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">Y</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_upward</span> - (Up)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogYNegAddress" /></td>
                                <td class="desc-cell">Negative Y Jog</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-z">Z</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_upward</span> + (Up)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogZPosAddress" /></td>
                                <td class="desc-cell">Positive Z Jog</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-z">Z</span></td>
                                <td class="dir-cell"><span class="material-symbols-outlined dir-icon">arrow_downward</span> - (Down)</td>
                                <td><input class="addr-input" type="number" min="0" max="999999" @bind="ViewModel.JogZNegAddress" /></td>
                                <td class="desc-cell">Negative Z Jog</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- ══════════════════════════════════════════════════════════
             SECTION: POSITION DISPLAY
             ══════════════════════════════════════════════════════════ -->
        @if (activeSection == "position")
        {
            <div class="section-header">
                <div>
                    <h2 class="section-title">
                        <span class="material-symbols-outlined">my_location</span>
                        Position Display Configuration
                    </h2>
                    <p class="section-subtitle">Coordinate transformations and unit scaling</p>
                </div>
                <div class="section-header-actions">
                    <button class="btn-ghost" @onclick="ResetPositionDefaults">
                        <span class="material-symbols-outlined">restart_alt</span>
                        Reset
                    </button>
                </div>
            </div>

            <!-- Card 1: Display Scaling -->
            <div class="settings-card">
                <div class="card-header accent-amber">
                    <span class="material-symbols-outlined">tune</span>
                    <div>
                        <h3 class="card-title">Position Scaling & Transformation</h3>
                        <p class="card-subtitle">Individual scaling factors and offsets per axis</p>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Global Config -->
                    <div class="scaling-grid">
                        <div class="scaling-group">
                            <label class="scale-label">Display Unit</label>
                            <select class="scale-select" @bind="ViewModel.PosUnit">
                                <option value="mm">mm (millimeters)</option>
                                <option value="cm">cm (centimeters)</option>
                                <option value="m">m (meters)</option>
                                <option value="deg">° (degrees)</option>
                            </select>
                        </div>
                        <div class="scaling-group">
                            <label class="scale-label">Decimal Places</label>
                            <input class="addr-input" type="number" min="0" max="6" @bind="ViewModel.PosDecimals" />
                        </div>
                    </div>

                    <div class="divider"></div>

                    <!-- Coordinate Source Mapping -->
                    <table class="config-table">
                        <thead>
                            <tr>
                                <th>Axis</th>
                                <th>Addr Type</th>
                                <th>Address Index</th>
                                <th>Read Mode</th>
                                <th>Source</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="axis-badge axis-x">X</span></td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.PosAddrTypeX">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.PosAddrIndexX" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.PosAddrXRead32" />
                                        32-bit (D only)
                                    </label>
                                </td>
                                <td class="mono-val">@ViewModel.PosAddrTypeX@ViewModel.PosAddrIndexX</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">Y</span></td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.PosAddrTypeY">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.PosAddrIndexY" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.PosAddrYRead32" />
                                        32-bit (D only)
                                    </label>
                                </td>
                                <td class="mono-val">@ViewModel.PosAddrTypeY@ViewModel.PosAddrIndexY</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-z">Z</span></td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.PosAddrTypeZ">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.PosAddrIndexZ" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.PosAddrZRead32" />
                                        32-bit (D only)
                                    </label>
                                </td>
                                <td class="mono-val">@ViewModel.PosAddrTypeZ@ViewModel.PosAddrIndexZ</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="divider"></div>

                    <!-- Individual Axis Scaling -->
                    <table class="config-table">
                        <thead>
                            <tr>
                                <th>Axis</th>
                                <th>Scaling Factor (raw × k)</th>
                                <th>Offset (+ b)</th>
                                <th>Formula</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="axis-badge axis-x">X</span></td>
                                <td><input class="addr-input" type="number" step="0.001" @bind="ViewModel.PosScaleX" /></td>
                                <td><input class="addr-input" type="number" step="0.01" @bind="ViewModel.PosOffsetX" /></td>
                                <td class="desc-cell mono-val">(@ViewModel.PosScaleX)x + @ViewModel.PosOffsetX</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">Y</span></td>
                                <td><input class="addr-input" type="number" step="0.001" @bind="ViewModel.PosScaleY" /></td>
                                <td><input class="addr-input" type="number" step="0.01" @bind="ViewModel.PosOffsetY" /></td>
                                <td class="desc-cell mono-val">(@ViewModel.PosScaleY)y + @ViewModel.PosOffsetY</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-z">Z</span></td>
                                <td><input class="addr-input" type="number" step="0.001" @bind="ViewModel.PosScaleZ" /></td>
                                <td><input class="addr-input" type="number" step="0.01" @bind="ViewModel.PosOffsetZ" /></td>
                                <td class="desc-cell mono-val">(@ViewModel.PosScaleZ)z + @ViewModel.PosOffsetZ</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="settings-card">
                <div class="card-header accent-blue">
                    <span class="material-symbols-outlined">view_list</span>
                    <div>
                        <h3 class="card-title">Axis Monitor Mapping</h3>
                        <p class="card-subtitle">Configure PLC addresses for Dashboard Axis Monitor</p>
                    </div>
                </div>
                <div class="card-body">
                    <table class="config-table">
                        <thead>
                            <tr>
                                <th>Axis</th>
                                <th>Item</th>
                                <th>Addr Type</th>
                                <th>Address Index</th>
                                <th>32-bit</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Position</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1PositionAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1PositionAddrIndex" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.Axis1PositionRead32" />
                                        32-bit
                                    </label>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Speed</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1SpeedAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1SpeedAddrIndex" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.Axis1SpeedRead32" />
                                        32-bit
                                    </label>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Error Code</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1ErrorAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1ErrorAddrIndex" /></td>
                                <td class="mono-val">--</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Warning Code</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1WarningAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1WarningAddrIndex" /></td>
                                <td class="mono-val">--</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Axis Status</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1StatusAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1StatusAddrIndex" /></td>
                                <td class="mono-val">--</td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-x">AX1</span></td>
                                <td class="param-name">Start No</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis1StartAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis1StartAddrIndex" /></td>
                                <td class="mono-val">--</td>
                            </tr>

                            <tr>
                                <td><span class="axis-badge axis-y">AX2</span></td>
                                <td class="param-name">Position</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis2PositionAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis2PositionAddrIndex" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.Axis2PositionRead32" />
                                        32-bit
                                    </label>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">AX2</span></td>
                                <td class="param-name">Speed</td>
                                <td>
                                    <select class="scale-select" style="max-width:90px;" @bind="ViewModel.Axis2SpeedAddrType">
                                        <option value="D">D</option>
                                        <option value="M">M</option>
                                        <option value="X">X</option>
                                        <option value="Y">Y</option>
                                        <option value="U0G">U0G</option>
                                    </select>
                                </td>
                                <td><input class="addr-input" type="number" min="0" @bind="ViewModel.Axis2SpeedAddrIndex" /></td>
                                <td>
                                    <label class="mono-val" style="display:flex;align-items:center;gap:6px;">
                                        <input type="checkbox" @bind="ViewModel.Axis2SpeedRead32" />
                                        32-bit
                                    </label>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="axis-badge axis-y">AX2</span></td>
                                <td class="param-name">Error Code</td>
                                <td>
