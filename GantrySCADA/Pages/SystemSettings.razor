    .scale-select { padding: 6px 12px; border-radius: 4px; border: 1px solid var(--c-outline-variant); background: var(--c-surface-container-low); color: var(--c-on-surface); font-size: 12px; }
    .divider { height: 1px; background: var(--c-outline-variant); margin: 20px 0; opacity: 0.5; }
