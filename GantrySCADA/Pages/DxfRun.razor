    private void SelectPoint(string sourceKey, double x, double y)
    {
        string label = $"P{_pickedPoints.Count + 1}";
        _pickedPoints.Add(new PickedPoint
        {
            SourceKey = sourceKey,
            Label = label,
            XUm = ToUm(x),
            YUm = ToUm(y)
        });

        ReindexPickedPointLabels();

        ViewModel.AddLog("UI", "info", $"{label}({_pickedPoints[^1].XUm}, {_pickedPoints[^1].YUm}) um selected");
    }

    private bool IsPointPicked(string sourceKey)
    {
        return _pickedPoints.Any(p => p.SourceKey == sourceKey);
    }

    private void ClearPickedPoints()
    {
        _pickedPoints.Clear();
    }

    private PickedPoint? FindPointByLabel(string label)
    {
        return _pickedPoints.FirstOrDefault(p => string.Equals(p.Label, label, StringComparison.OrdinalIgnoreCase));
    }

    private int ToUm(double mm)
    {
        return (int)Math.Round(mm * 1000.0, MidpointRounding.AwayFromZero);
    }

    private void GeneratePlcFrames()
    {
        _generatedFrames.Clear();
        _scriptStatus = string.Empty;
        _nextSendIndex = 0;
        _activeSendIndex = -1;

        if (TryGenerateFramesFromSelectedContour())
            return;

        PickedPoint? previousEndPoint = null;

        var lines = _motionScript
            .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x) && !x.StartsWith("#") && !x.StartsWith("//"))
            .ToList();

        if (lines.Count == 0)
        {
            _scriptStatus = "Script is empty.";
            return;
        }

        for (int i = 0; i < lines.Count; i++)
        {
            string line = lines[i];
            string[] parts = line.Split(new[] { ' ', '\t', ',' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length < 2)
            {
                _scriptStatus = $"Line {i + 1}: invalid syntax.";
                return;
            }

            string cmd = parts[0].ToUpperInvariant();
            string posLabel = parts[1].ToUpperInvariant();
            var endPt = FindPointByLabel(posLabel);
            if (endPt == null)
            {
                _scriptStatus = $"Line {i + 1}: point '{posLabel}' not found in Selected Points.";
                return;
            }

            var frame = new PlcMotionFrame
            {
                CommandCode = cmd switch
                {
                    "MOVEL" => 1,
                    "MOVEC" => 2,
                    _ => -1
                },
                PosXUm = endPt.XUm,
                PosYUm = endPt.YUm,
                ArcXUm = 0,
                ArcYUm = 0,
                SpeedMmMin = 1000,
                DwellMs = 0,
                BitRun = 1
            };

            if (frame.CommandCode < 0)
            {
                _scriptStatus = $"Line {i + 1}: unsupported command '{parts[0]}'. Use MoveL/MoveC.";
                return;
            }

            // Arc command: MoveC Pn Ck [speed dwell]
            if (cmd == "MOVEC")
            {
                // MoveC uses the previous command's end point as arc start point.
                if (previousEndPoint == null)
                {
                    _scriptStatus = $"Line {i + 1}: MoveC requires a previous endpoint as arc start. Add a MoveL before it.";
                    return;
                }

                if (parts.Length < 3)
                {
                    _scriptStatus = $"Line {i + 1}: MoveC requires center label. Example: MoveC P2 C1";
                    return;
                }

                string centerLabel = parts[2].ToUpperInvariant();
                var centerPt = FindPointByLabel(centerLabel);
                if (centerPt == null)
                {
                    _scriptStatus = $"Line {i + 1}: center point '{centerLabel}' not found.";
                    return;
                }

                frame.ArcXUm = centerPt.XUm;
                frame.ArcYUm = centerPt.YUm;

                if (parts.Length >= 4 && int.TryParse(parts[3], out int arcSpd))
                    frame.SpeedMmMin = Math.Max(1, arcSpd);
                if (parts.Length >= 5 && int.TryParse(parts[4], out int arcDw))
                    frame.DwellMs = Math.Max(0, arcDw);

                // Start point is implicit from previous command.
                ViewModel.AddLog("UI", "info", $"Line {i + 1}: MoveC start=P({previousEndPoint.XUm}, {previousEndPoint.YUm})um end={posLabel} center={centerLabel}");
            }
            else
            {
                if (parts.Length >= 3 && int.TryParse(parts[2], out int spd))
                    frame.SpeedMmMin = Math.Max(1, spd);
                if (parts.Length >= 4 && int.TryParse(parts[3], out int dw))
                    frame.DwellMs = Math.Max(0, dw);
            }

            _generatedFrames.Add(frame);
            previousEndPoint = endPt;
        }

        _scriptStatus = $"Generated {_generatedFrames.Count} frame(s).";
        ViewModel.AddLog("UI", "success", _scriptStatus, "PLC frame gen");
    }

    private bool TryGenerateFramesFromSelectedContour()
    {
        var contour = ViewModel.SelectedContour;
        if (contour == null)
            return false;

        const int defaultSpeed = 1000;
        const int defaultDwell = 0;

        void AddMoveL(double xMm, double yMm)
        {
            _generatedFrames.Add(new PlcMotionFrame
            {
                CommandCode = 1,
                PosXUm = ToUm(xMm),
                PosYUm = ToUm(yMm),
                ArcXUm = 0,
                ArcYUm = 0,
                SpeedMmMin = defaultSpeed,
                DwellMs = defaultDwell,
                BitRun = 1
            });
        }

        void AddMoveC(double endXmm, double endYmm, double cxMm, double cyMm)
        {
            _generatedFrames.Add(new PlcMotionFrame
            {
                CommandCode = 2,
                PosXUm = ToUm(endXmm),
                PosYUm = ToUm(endYmm),
                ArcXUm = ToUm(cxMm),
                ArcYUm = ToUm(cyMm),
                SpeedMmMin = defaultSpeed,
                DwellMs = defaultDwell,
                BitRun = 1
            });
        }

        if (contour.IsCircle)
        {
            if (contour.Points.Count < 1 || !contour.HasCenter)
            {
                _scriptStatus = "Selected circle is missing start/center info.";
                return true;
            }

            var start = contour.Points[0];
            // Single MoveC command: end = start, center = C. Useful for cyclic single-step send.
            AddMoveC(start.X, start.Y, contour.CenterX, contour.CenterY);
        }
        else if (contour.IsArc)
        {
            if (contour.Points.Count < 2 || !contour.HasCenter)
            {
                _scriptStatus = "Selected arc is missing start/end/center info.";
                return true;
            }

            var start = contour.Points[0];
            var end = contour.Points[1];
            AddMoveL(start.X, start.Y);
            AddMoveC(end.X, end.Y, contour.CenterX, contour.CenterY);
        }
        else
        {
            if (contour.Points.Count == 0)
            {
                _scriptStatus = "Selected contour has no points.";
                return true;
            }

            foreach (var p in contour.Points)
                AddMoveL(p.X, p.Y);

            if (contour.IsClosed && contour.Points.Count > 1)
            {
                var first = contour.Points[0];
                var last = contour.Points[^1];
                if (Math.Abs(first.X - last.X) > 1e-9 || Math.Abs(first.Y - last.Y) > 1e-9)
                    AddMoveL(first.X, first.Y);
            }
        }

        _scriptStatus = $"Auto generated {_generatedFrames.Count} frame(s) from contour '{contour.Name}'.";
        ViewModel.AddLog("UI", "success", _scriptStatus, "PLC frame auto-gen");
        return true;
    }

    private async Task SendFramesToPlcAsync()
    {
        if (_generatedFrames.Count == 0)
        {
            _scriptStatus = "No generated frame to send.";
            return;
        }

        if (!ViewModel.Status)
        {
            _scriptStatus = "PLC is offline.";
            return;
        }

        if (_isSending)
            return;

        _isSending = true;

        try
        {
            for (int i = _nextSendIndex; i < _generatedFrames.Count; i++)
            {
                _activeSendIndex = i;
                await SendFrameToPlcAsync(_generatedFrames[i]);
                _nextSendIndex = i + 1;
            }

            _scriptStatus = $"Sent {_generatedFrames.Count} frame(s) to PLC.";
            ViewModel.AddLog("PLC", "success", _scriptStatus, "PLC send");
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task SendSingleFrameToPlcAsync()
    {
        if (_generatedFrames.Count == 0)
        {
            _scriptStatus = "No generated frame to send.";
            return;
        }

        if (!ViewModel.Status)
        {
            _scriptStatus = "PLC is offline.";
            return;
        }

        if (_isSending)
            return;

        _isSending = true;
        try
        {
            int sendIndex = _nextSendIndex % _generatedFrames.Count;
            _activeSendIndex = sendIndex;

            await SendFrameToPlcAsync(_generatedFrames[sendIndex]);

            _nextSendIndex = (sendIndex + 1) % _generatedFrames.Count;
            int nextHumanIndex = _nextSendIndex + 1;
            _scriptStatus = $"Sent frame {sendIndex + 1}/{_generatedFrames.Count}. Next: {nextHumanIndex}/{_generatedFrames.Count}.";
            ViewModel.AddLog("PLC", "info", _scriptStatus, "PLC step send");
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task SendFrameToPlcAsync(PlcMotionFrame f)
    {
        ViewModel.MarkPendingWrite("D", DCmd, f.CommandCode);
        ViewModel.MarkPendingWrite("D", DPosX, f.PosXUm);
        ViewModel.MarkPendingWrite("D", DPosY, f.PosYUm);
        ViewModel.MarkPendingWrite("D", DArcX, f.ArcXUm);
        ViewModel.MarkPendingWrite("D", DArcY, f.ArcYUm);
        ViewModel.MarkPendingWrite("D", DSpeed, f.SpeedMmMin);
        ViewModel.MarkPendingWrite("D", DDwell, f.DwellMs);

        // Pulse run bit for each frame: 1 then 0
        ViewModel.MarkPendingWrite("D", DRun, f.BitRun);
        await Task.Delay(80);
        ViewModel.MarkPendingWrite("D", DRun, 0);

        await Task.Delay(Math.Max(40, f.DwellMs));
    }

    private void RemovePickedPoint(PickedPoint point)
    {
        if (_pickedPoints.Remove(point))
        {
            ReindexPickedPointLabels();
            ViewModel.AddLog("UI", "info", $"Removed {point.Label}({point.XUm}, {point.YUm}) um");
        }
    }

    private void ReindexPickedPointLabels()
    {
        for (int i = 0; i < _pickedPoints.Count; i++)
            _pickedPoints[i].Label = $"P{i + 1}";
    }

    private string GetSvgTransform()
    {
        string zoom = _viewportZoom.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        string tx = _viewportTx.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        string ty = _viewportTy.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        return $"translate({tx} {ty}) translate(100 100) scale({zoom}) translate(-100 -100)";
    }

    private void ZoomIn()
    {
        _viewportZoom = Math.Min(MaxZoom, _viewportZoom * 1.2);
    }

    private void ZoomOut()
    {
        _viewportZoom = Math.Max(MinZoom, _viewportZoom / 1.2);
    }

    private void ResetZoom()
    {
        _viewportZoom = 1.0;
        _viewportTx = 0.0;
        _viewportTy = 0.0;
        _isPanning = false;
    }

    private void OnViewportWheel(Microsoft.AspNetCore.Components.Web.WheelEventArgs e)
    {
        if (e.DeltaY < 0)
            ZoomIn();
        else if (e.DeltaY > 0)
            ZoomOut();
    }

    private void OnViewportMouseDown(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        // Middle button only: press-and-drag to pan viewport.
        if (e.Button != 1)
            return;

        _isPanning = true;
        _panStartMouseX = e.ClientX;
        _panStartMouseY = e.ClientY;
        _panStartTx = _viewportTx;
        _panStartTy = _viewportTy;
    }

    private void OnViewportMouseMove(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (!_isPanning)
            return;

        double dx = e.ClientX - _panStartMouseX;
        double dy = e.ClientY - _panStartMouseY;

        _viewportTx = _panStartTx + (dx * PanScale) / Math.Max(_viewportZoom, 0.0001);
        _viewportTy = _panStartTy + (dy * PanScale) / Math.Max(_viewportZoom, 0.0001);
    }

    private void OnViewportMouseUp(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (_isPanning && e.Button == 1)
            _isPanning = false;
    }

    private void OnViewportMouseLeave(Microsoft.AspNetCore.Components.Web.MouseEventArgs _)
    {
        _isPanning = false;
    }

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        base.OnInitialized();
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
    }
