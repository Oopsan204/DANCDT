@page "/dxf-run"
@inject WPF_Test_PLC20260124.MainViewModel ViewModel
@inject IJSRuntime JS
@using System.IO
@implements IDisposable

<div class="space-y-6 pb-20">
    <!-- Header / Breadcrumbs -->
    <div class="flex justify-between items-end mb-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tighter text-on-surface font-headline uppercase">DXF Advanced Control Hub</h1>
            <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest mt-1">Industrial Trajectory & Visual Validation Engine</p>
        </div>
        <div class="flex gap-2">
            <div class="px-3 py-1 rounded bg-surface-container-high border border-outline-variant/30 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full @(ViewModel.Status ? "bg-green-500" : "bg-red-500") shadow-[0_0_8px_currentColor]"></div>
                <span class="text-[10px] font-bold font-label uppercase text-on-surface-variant">PLC: @(ViewModel.Status ? "CONNECTED" : "OFFLINE")</span>
            </div>
        </div>
    </div>

    <!-- Main Hub Layout: 3 Columns -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <!-- LEFT COLUMN: Source & Manager (3 units) -->
        <div class="lg:col-span-3 space-y-6">
            <!-- DXF Source Block -->
            <section class="bg-surface-container-lowest rounded-xl p-5 shadow-sm border border-outline-variant/10 relative overflow-hidden">
                <div class="flex items-center gap-2 mb-4 border-b border-outline-variant/10 pb-2">
                    <span class="material-symbols-outlined text-primary text-sm">upload_file</span>
                    <h2 class="text-[11px] font-bold font-label uppercase tracking-wider text-on-surface-variant">DXF Source</h2>
                </div>
                <div class="space-y-4">
                    <div class="flex gap-2">
                        <input type="text" @bind="ViewModel.DxfFilePath" placeholder="C:\Paths\Project.dxf" 
                               class="flex-grow bg-surface-container-low border border-outline-variant/20 rounded px-3 py-2 text-xs font-mono focus:outline-none focus:border-primary transition-all shadow-inner"/>
                        <button class="bg-surface-container-high hover:bg-surface-container-highest text-on-surface p-2 rounded transition-colors shadow-sm"
                            @onclick='() => ViewModel.BrowseAndLoadDxf()'>
                            <span class="material-symbols-outlined text-lg">folder_open</span>
                        </button>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <button @onclick='() => ViewModel.LoadDxfAdvanced(ViewModel.DxfFilePath)' 
                                class="bg-primary hover:brightness-110 text-white py-2 rounded text-[10px] font-bold uppercase tracking-wider transition-all shadow-md">
                            Load DXF
                        </button>
                        <button class="bg-surface-container-high hover:bg-surface-container-highest text-on-surface py-2 rounded text-[10px] font-bold uppercase tracking-wider transition-all"
                                @onclick='() => ViewModel.LoadDxfAdvanced(ViewModel.DxfFilePath)'>
                            Reload
                        </button>
                    </div>
                    <div class="mt-4 p-3 bg-surface-container-low rounded border-l-2 border-primary space-y-2">
                        <div class="flex justify-between text-[10px] font-mono text-on-surface-variant">
                            <span>Entities:</span>
                            <span class="text-on-surface font-bold text-primary">@ViewModel.DxfEntityCount</span>
                        </div>
                        <div class="flex justify-between text-[10px] font-mono text-on-surface-variant">
                            <span>Points:</span>
                            <span class="text-on-surface font-bold">@ViewModel.DxfSampleCount</span>
                        </div>
                        <div class="flex justify-between text-[10px] font-mono text-on-surface-variant">
                            <span>Layers:</span>
                            <span class="text-on-surface font-bold">@ViewModel.DxfLayerCount</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Contour Manager Block -->
            <section class="bg-surface-container-lowest rounded-xl p-5 shadow-sm border border-outline-variant/10 flex flex-col h-[500px]">
                <div class="flex items-center justify-between mb-4 border-b border-outline-variant/10 pb-2">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-sm">polyline</span>
                        <h2 class="text-[11px] font-bold font-label uppercase tracking-wider text-on-surface-variant">Contour Manager</h2>
                    </div>
                    <select @bind="ViewModel.SelectedDxfLayer" class="bg-surface-container-low border-none rounded text-[9px] font-bold uppercase py-1 px-2 focus:ring-0">
                        @foreach(var layer in ViewModel.DxfLayers)
                        {
                            <option value="@layer">@layer</option>
                        }
                    </select>
                </div>
                <div class="flex-grow overflow-y-auto pr-1 custom-scrollbar">
                    <table class="w-full text-left border-separate border-spacing-y-1">
                        <thead>
                            <tr class="text-[9px] font-label text-on-surface-variant/60 uppercase tracking-tighter">
                                <th class="pb-2 pl-2">Name</th>
                                <th class="pb-2">Length</th>
                                <th class="pb-2">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in ViewModel.DxfContours.Where(c => ViewModel.SelectedDxfLayer == "All" || c.Layer == ViewModel.SelectedDxfLayer))
                            {
                                <tr class="group hover:bg-surface-container-low transition-colors cursor-pointer @(ViewModel.SelectedContour == item ? "bg-surface-container-high" : "bg-surface-container-low/30")"
                                    @onclick="() => SelectContour(item)">
                                    <td class="py-2 pl-2 rounded-l flex items-center gap-1">
                                        <div class="w-1 h-3 rounded-full @(item.IsClosed ? "bg-green-500" : "bg-blue-500/50") mr-1"></div>
                                        <span class="text-[10px] font-mono font-bold text-on-surface">@item.Name</span>
                                    </td>
                                    <td class="text-[10px] font-mono text-on-surface-variant italic">@item.Length.ToString("F1")mm</td>
                                    <td class="py-2 pr-2 rounded-r text-right opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined text-primary text-sm">visibility</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>

        <!-- CENTER COLUMN: Visual Validation (6 units) -->
        <div class="lg:col-span-6">
            <section class="bg-surface-container-lowest rounded-xl shadow-lg border border-outline-variant/10 overflow-hidden flex flex-col h-full min-h-[700px]">
                <!-- Workspace Header -->
                <div class="bg-surface-container-high/30 p-4 border-b border-outline-variant/10 flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">analytics</span>
                        <div>
                            <span class="text-[11px] font-bold font-label uppercase tracking-widest text-on-surface">Visual Workspace</span>
                            <div class="flex gap-4 mt-0.5">
                                <span class="text-[9px] font-mono text-on-surface-variant uppercase tracking-tighter">X Range: <b class="text-primary">@ViewModel.DxfXMin.ToString("F1"):@ViewModel.DxfXMax.ToString("F1")</b></span>
                                <span class="text-[9px] font-mono text-on-surface-variant uppercase tracking-tighter">Y Range: <b class="text-primary">@ViewModel.DxfYMin.ToString("F1"):@ViewModel.DxfYMax.ToString("F1")</b></span>
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-1">
                        <button class="p-1.5 hover:bg-surface-container-high rounded" title="Zoom In" @onclick="ZoomIn"><span class="material-symbols-outlined text-sm">zoom_in</span></button>
                        <button class="p-1.5 hover:bg-surface-container-high rounded" title="Zoom Out" @onclick="ZoomOut"><span class="material-symbols-outlined text-sm">zoom_out</span></button>
                        <button class="p-1.5 hover:bg-surface-container-high rounded" title="Reset" @onclick="ResetZoom"><span class="material-symbols-outlined text-sm">refresh</span></button>
                    </div>
                </div>

                <!-- SVG Preview Area -->
                <div class="flex-grow bg-[#0f172a] relative overflow-hidden group">
                    <!-- Grid Lines Overlay -->
                    <div class="absolute inset-0 opacity-20" 
                         style="background-image: radial-gradient(#334155 1px, transparent 1px); background-size: 20px 20px;"></div>
                    
                    <div class="flex items-center justify-center h-full p-10 select-none"
                        style="cursor:@(_isPanning ? "grabbing" : "grab")"
                        @onwheel="OnViewportWheel"
                        @onwheel:preventDefault="true"
                        @onmousedown="OnViewportMouseDown"
                        @onmousedown:preventDefault="true"
                        @onmousemove="OnViewportMouseMove"
                        @onmouseup="OnViewportMouseUp"
                        @onmouseleave="OnViewportMouseLeave">
                        @if(!string.IsNullOrEmpty(ViewModel.DxfPreviewPathData))
                        {
                            <svg viewBox="0 0 200 200" class="w-full h-full max-h-[500px] drop-shadow-[0_0_15px_rgba(13,110,253,0.3)]">
                                <g transform="@GetSvgTransform()">
                                    <path d="@ViewModel.DxfPreviewPathData" 
                                          fill="none" 
                                          stroke="#0d6efd" 
                                          stroke-width="1"
                                          stroke-linecap="round"
                                          stroke-linejoin="round"
                                          class="transition-all duration-700 ease-out" />

                                    @if (ViewModel.SelectedContour?.Points != null)
                                    {
                                        string contourKey = GetContourKey(ViewModel.SelectedContour);
                                        @for (int i = 0; i < ViewModel.SelectedContour.Points.Count; i++)
                                        {
                                            var point = ViewModel.SelectedContour.Points[i];
                                            var sx = ToSvgX(point.X);
                                            var sy = ToSvgY(point.Y);
                                            string pointKey = $"{contourKey}:V:{i}";
                                            bool isPicked = IsPointPicked(pointKey);

                                            <circle cx="@sx" cy="@sy"
                                                    r="4.8"
                                                    fill="rgba(255,255,255,0.001)"
                                                    style="cursor:pointer"
                                                    @onclick="() => SelectPoint(pointKey, point.X, point.Y)">
                                                <title>@($"Point {i + 1}: ({point.X:F3}, {point.Y:F3})")</title>
                                            </circle>

                                            <circle cx="@sx" cy="@sy"
                                                    r="@(isPicked ? "2.4" : "1.7")"
                                                    fill="@(isPicked ? "#f97316" : "#38bdf8")"
                                                    stroke="#ffffff"
                                                    stroke-width="0.35"
                                                    style="cursor:pointer"
                                                    @onclick="() => SelectPoint(pointKey, point.X, point.Y)">
                                                <title>@($"Point {i + 1}: ({point.X:F3}, {point.Y:F3})")</title>
                                            </circle>
                                        }
                                    }

                                    @if (ViewModel.SelectedContour?.HasCenter == true)
                                    {
                                        var cx = ToSvgX(ViewModel.SelectedContour.CenterX);
                                        var cy = ToSvgY(ViewModel.SelectedContour.CenterY);
                                        string centerKey = $"{GetContourKey(ViewModel.SelectedContour)}:CENTER";
                                        bool centerPicked = IsPointPicked(centerKey);

                                        <circle cx="@cx" cy="@cy"
                                                r="5.2"
                                                fill="rgba(255,255,255,0.001)"
                                                style="cursor:pointer"
                                                @onclick='() => SelectPoint(centerKey, ViewModel.SelectedContour.CenterX, ViewModel.SelectedContour.CenterY)'>
                                            <title>@($"Center point: ({ViewModel.SelectedContour.CenterX:F3}, {ViewModel.SelectedContour.CenterY:F3})")</title>
                                        </circle>

                                        <circle cx="@cx" cy="@cy" r="2.8" fill="@(centerPicked ? "#f97316" : "#f59e0b")" stroke="#ffffff" stroke-width="0.45"
                                                style="cursor:pointer"
                                                @onclick='() => SelectPoint(centerKey, ViewModel.SelectedContour.CenterX, ViewModel.SelectedContour.CenterY)'>
                                            <title>@($"Center: ({ViewModel.SelectedContour.CenterX:F3}, {ViewModel.SelectedContour.CenterY:F3})")</title>
                                        </circle>
                                        <line x1="@(cx - 4.0)" y1="@cy" x2="@(cx + 4.0)" y2="@cy" stroke="#f59e0b" stroke-width="0.5" />
                                        <line x1="@cx" y1="@(cy - 4.0)" x2="@cx" y2="@(cy + 4.0)" stroke="#f59e0b" stroke-width="0.5" />
                                    }
                                </g>
                            </svg>
                        }
                        else
                        {
                            <div class="text-on-surface-variant/30 flex flex-col items-center gap-3">
                                <span class="material-symbols-outlined text-6xl">draft</span>
                                <span class="text-xs font-label uppercase tracking-widest">No DXF Data Loaded</span>
                            </div>
                        }
                    </div>

                    <!-- Floating Tooltip -->
                    <div class="absolute bottom-4 left-4 bg-surface-container-highest/80 backdrop-blur-md px-3 py-1 rounded text-[9px] font-mono text-white tracking-widest border border-white/10 uppercase">
                        Units: Millimeters (mm)
                    </div>
                    <div class="absolute top-4 right-4 flex flex-col gap-2">
                         <div class="bg-surface-container-highest/60 backdrop-blur pb-1 px-2 rounded border border-white/5">
                            <span class="text-[8px] font-bold text-white/50 block mt-1">AXIS X</span>
                            <span class="text-xs text-primary font-bold font-mono">@(ViewModel.arr_R32.Length > 0 ? (ViewModel.arr_R32[0]/20.0).ToString("F2") : "0.00")</span>
                         </div>
                         <div class="bg-surface-container-highest/60 backdrop-blur pb-1 px-2 rounded border border-white/5">
                            <span class="text-[8px] font-bold text-white/50 block mt-1">AXIS Y</span>
                            <span class="text-xs text-primary font-bold font-mono">@(ViewModel.arr_R32.Length > 2 ? (ViewModel.arr_R32[1]/20.0).ToString("F2") : "0.00")</span>
                         </div>
                    </div>
                </div>

                <!-- Diagnostics Hub -->
                <div class="bg-surface-container-low p-4 space-y-3">
                    <div class="flex items-center justify-between">
                         <h3 class="text-[10px] font-bold font-label uppercase tracking-widest text-on-surface-variant">System Diagnostics</h3>
                         <button class="text-[9px] font-bold text-primary uppercase hover:underline">Export Session Log</button>
                    </div>
                    <div class="space-y-1 h-32 overflow-y-auto pr-2 custom-scrollbar">
                        <div class="flex gap-2 text-[10px] font-mono">
                            <span class="text-primary font-bold">[PARSE]</span>
                            <span class="text-on-surface-variant">DXF successfully initialized: @(string.IsNullOrEmpty(ViewModel.DxfFilePath) ? "None" : Path.GetFileName(ViewModel.DxfFilePath))</span>
                        </div>
                        <div class="flex gap-2 text-[10px] font-mono">
                            <span class="text-green-500 font-bold">[SAFETY]</span>
                            <span class="text-on-surface-variant">Bounding area validated for Gantry Alpha limits.</span>
                        </div>
                        @if(ViewModel.SelectedContour != null)
                        {
                            <div class="flex gap-2 text-[10px] font-mono">
                                <span class="text-orange-500 font-bold">[SELECT]</span>
                                <span class="text-on-surface-variant">Active: @ViewModel.SelectedContour.Name (L=@ViewModel.SelectedContour.Length.ToString("F1") mm)</span>
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>

        <!-- RIGHT COLUMN: Setup & Execution (3 units) -->
        <div class="lg:col-span-3 space-y-6">
            <section class="bg-surface-container-lowest rounded-xl p-5 shadow-sm border border-outline-variant/10">
                <div class="flex items-center justify-between mb-4 border-b border-outline-variant/10 pb-2">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-sm">point_scan</span>
                        <h2 class="text-[11px] font-bold font-label uppercase tracking-wider text-on-surface-variant">Selected Points</h2>
                    </div>
                    <button class="text-[9px] font-bold text-primary uppercase hover:underline"
                            @onclick="ClearPickedPoints">Clear</button>
                </div>

                @if (_pickedPoints.Count == 0)
                {
                    <p class="text-[10px] text-on-surface-variant">Click points in the DXF viewport to add entries like P1(x_um,y_um).</p>
                }
                else
                {
                    <div class="max-h-44 overflow-y-auto custom-scrollbar border border-outline-variant/15 rounded">
                        <table class="w-full text-left">
                            <thead class="bg-surface-container-low">
                                <tr class="text-[9px] font-bold uppercase text-on-surface-variant">
                                    <th class="px-2 py-1">Tag</th>
                                    <th class="px-2 py-1">X(um)</th>
                                    <th class="px-2 py-1">Y(um)</th>
                                    <th class="px-2 py-1 text-right">Del</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _pickedPoints.Count; i++)
                                {
                                    var p = _pickedPoints[i];
                                    <tr class="text-[10px] font-mono border-t border-outline-variant/10">
                                        <td class="px-2 py-1 text-primary font-bold">@p.Label</td>
                                        <td class="px-2 py-1">@p.XUm</td>
                                        <td class="px-2 py-1">@p.YUm</td>
                                        <td class="px-2 py-1 text-right">
                                            <button class="text-red-500 hover:text-red-600" title="Remove point" @onclick="() => RemovePickedPoint(p)">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="bg-surface-container-lowest rounded-xl p-5 shadow-lg border border-outline-variant/20 overflow-hidden relative">
                <div class="flex items-center gap-2 mb-4 border-b border-outline-variant/10 pb-2">
                    <span class="material-symbols-outlined text-primary text-sm">terminal</span>
                    <h2 class="text-[11px] font-bold font-label uppercase tracking-wider text-on-surface-variant">PLC Motion Script</h2>
                </div>

                <div class="space-y-3">
                    <p class="text-[10px] text-on-surface-variant">Commands: <span class="font-mono">MoveL P1 [speed dwell]</span>, <span class="font-mono">MoveC P2 C1 [speed dwell]</span></p>

                    <div class="space-y-1">
                        <label class="text-[9px] font-bold uppercase text-on-surface-variant">Script Input</label>
                        <textarea @bind="_motionScript"
                                  rows="9"
                                  spellcheck="false"
                                  class="w-full bg-[#020817] border border-outline-variant/30 rounded px-3 py-2 text-[11px] leading-5 text-sky-100 font-mono resize-y"></textarea>
                    </div>

                    <div class="grid grid-cols-3 gap-2">
                        <button class="bg-primary hover:brightness-110 text-white py-2 rounded text-[10px] font-bold uppercase tracking-wider transition-all"
                                @onclick="GeneratePlcFrames">
                            GenCode
                        </button>
                        <button class="bg-amber-600 hover:brightness-110 text-white py-2 rounded text-[10px] font-bold uppercase tracking-wider transition-all"
                                @onclick="SendSingleFrameToPlcAsync"
                                disabled="@(!_generatedFrames.Any() || !ViewModel.Status || _isSending)">
                            Send 1 Cmd
                        </button>
                        <button class="bg-emerald-600 hover:brightness-110 text-white py-2 rounded text-[10px] font-bold uppercase tracking-wider transition-all"
                                @onclick="SendFramesToPlcAsync"
                                disabled="@(!_generatedFrames.Any() || !ViewModel.Status || _isSending)">
                            Send PLC
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_scriptStatus))
                    {
                        <div class="text-[10px] font-mono text-amber-300 bg-surface-container-low border border-outline-variant/20 rounded px-2 py-1">@_scriptStatus</div>
                    }

                    <div class="max-h-52 overflow-y-auto custom-scrollbar border border-outline-variant/15 rounded">
                        <table class="w-full text-left">
                            <thead class="bg-surface-container-low sticky top-0">
                                <tr class="text-[9px] font-bold uppercase text-on-surface-variant">
                                    <th class="px-2 py-1">Cmd</th>
                                    <th class="px-2 py-1">POS_X(um)</th>
                                    <th class="px-2 py-1">POS_Y(um)</th>
                                    <th class="px-2 py-1">ARC_X(um)</th>
                                    <th class="px-2 py-1">ARC_Y(um)</th>
                                    <th class="px-2 py-1">SPD</th>
                                    <th class="px-2 py-1">DWELL(ms)</th>
                                    <th class="px-2 py-1">BIT_RUN</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _generatedFrames.Count; i++)
                                {
                                    var f = _generatedFrames[i];
                                    bool isActiveRow = i == _activeSendIndex;
                                    <tr class="text-[10px] font-mono border-t border-outline-variant/10 @(isActiveRow ? "bg-emerald-500/20" : "")">
                                        <td class="px-2 py-1">@f.CommandCode</td>
                                        <td class="px-2 py-1">@f.PosXUm</td>
                                        <td class="px-2 py-1">@f.PosYUm</td>
                                        <td class="px-2 py-1">@f.ArcXUm</td>
                                        <td class="px-2 py-1">@f.ArcYUm</td>
                                        <td class="px-2 py-1">@f.SpeedMmMin</td>
                                        <td class="px-2 py-1">@f.DwellMs</td>
                                        <td class="px-2 py-1">@f.BitRun</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--outline-variant);
        border-radius: 10px;
        opacity: 0.3;
    }
    
    @@keyframes pulse {
        0%, 100% { opacity: 0.05; }
        50% { opacity: 0.15; }
    }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
</style>

@code {
        private void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
        {
            _ = InvokeAsync(StateHasChanged);
        }

    private sealed class PickedPoint
    {
        public string SourceKey { get; set; } = "";
        public string Label { get; set; } = "";
        public int XUm { get; set; }
        public int YUm { get; set; }
    }

    private readonly List<PickedPoint> _pickedPoints = new();
    private double _viewportZoom = 1.0;
    private const double MinZoom = 0.6;
    private const double MaxZoom = 8.0;
    private double _viewportTx = 0.0;
    private double _viewportTy = 0.0;
    private bool _isPanning = false;
    private double _panStartMouseX = 0.0;
    private double _panStartMouseY = 0.0;
    private double _panStartTx = 0.0;
    private double _panStartTy = 0.0;
    private const double PanScale = 0.35;

    private const int DCmd = 1000;
    private const int DPosX = 1100;
    private const int DPosY = 1200;
    private const int DArcX = 1300;
    private const int DArcY = 1400;
    private const int DSpeed = 1500;
    private const int DDwell = 1600;
    private const int DRun = 1700;

    private string _motionScript = "MoveL P1 1000 0\nMoveC P2 C1 1000 0";
    private string _scriptStatus = string.Empty;
    private readonly List<PlcMotionFrame> _generatedFrames = new();
    private int _nextSendIndex = 0;
    private int _activeSendIndex = -1;
    private bool _isSending = false;

    private sealed class PlcMotionFrame
    {
        public int CommandCode { get; set; }
        public int PosXUm { get; set; }
        public int PosYUm { get; set; }
        public int ArcXUm { get; set; }
        public int ArcYUm { get; set; }
        public int SpeedMmMin { get; set; }
        public int DwellMs { get; set; }
        public int BitRun { get; set; } = 1;
    }

    private double ToSvgX(double x)
    {
        double width = ViewModel.DxfXMax - ViewModel.DxfXMin;
        double height = ViewModel.DxfYMax - ViewModel.DxfYMin;
        double scale = 200.0 / Math.Max(width, height == 0 ? 1 : height);
        return (x - ViewModel.DxfXMin) * scale;
    }

    private double ToSvgY(double y)
    {
        double width = ViewModel.DxfXMax - ViewModel.DxfXMin;
        double height = ViewModel.DxfYMax - ViewModel.DxfYMin;
        double scale = 200.0 / Math.Max(width, height == 0 ? 1 : height);
        return 200.0 - (y - ViewModel.DxfYMin) * scale;
    }

