@page "/dxf-run"
@inject WPF_Test_PLC20260124.MainViewModel ViewModel
@inject IJSRuntime JSRuntime
@using System.IO

<div class="h-[calc(100vh-60px)] w-full flex flex-col p-6 gap-6 bg-surface text-on-surface font-body overflow-hidden">
    
    <!-- Top Bar -->
    <div class="flex items-start justify-between w-full shrink-0">
        <div class="flex gap-4 w-1/2">
            <!-- CAD Path & File Input -->
            <div class="flex items-center bg-surface-container-lowest border border-outline-variant/50 flex-1 h-10 px-3 overflow-hidden">
                <span class="material-symbols-outlined text-outline mr-2">folder_open</span>
                <span class="text-xs font-mono text-outline flex-1 truncate" title="@ViewModel.DxfFilePath">
                    @(string.IsNullOrWhiteSpace(ViewModel.DxfFilePath) ? "Đường dẫn cad / Tên file" : $"{ViewModel.DxfFilePath} ({Path.GetFileName(ViewModel.DxfFilePath)})")
                </span>
                <button class="bg-primary-container text-on-primary-fixed font-headline font-bold text-xs px-4 h-full ml-3 hover:bg-primary-fixed-dim transition-colors uppercase" @onclick="() => ViewModel.BrowseAndLoadDxf()">
                    OPEN
                </button>
            </div>
        </div>

        <!-- Status Indicators -->
        <div class="flex gap-6 items-end mr-4">
            <div class="flex flex-col items-center gap-2">
                <span class="text-outline text-[10px] font-bold tracking-widest uppercase">Ready</span>
                <div class="w-6 h-6 rounded-none border border-outline-variant/50 transition-colors @(ViewModel.Status && !ViewModel.IsDxfRunning ? "bg-secondary-container shadow-[0_0_15px_var(--c-secondary-container)]" : "bg-surface-container-low")"></div>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-outline text-[10px] font-bold tracking-widest uppercase">Busy</span>
                <div class="w-6 h-6 rounded-none border border-outline-variant/50 transition-colors @(ViewModel.IsDxfRunning ? "bg-primary shadow-[0_0_15px_var(--c-primary)]" : "bg-surface-container-low")"></div>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-outline text-[10px] font-bold tracking-widest uppercase">Home</span>
                <div class="w-6 h-6 rounded-none bg-surface-container-low border border-outline-variant/50"></div>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-outline text-[10px] font-bold tracking-widest uppercase">Error</span>
                <div class="w-6 h-6 rounded-none border border-outline-variant/50 transition-colors @(!ViewModel.Status ? "bg-error shadow-[0_0_15px_var(--c-error)]" : "bg-surface-container-low")"></div>
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 flex gap-6 min-h-0 overflow-hidden">
        
        <!-- View CAD Box (Center-Left) -->
        <div class="flex-[2] border border-primary-container/20 relative flex items-center justify-center overflow-hidden" style="background-color: #0d1117; background-image: linear-gradient(to right, rgba(100, 180, 200, 0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(100, 180, 200, 0.08) 1px, transparent 1px); background-size: 40px 40px;">
            @if (string.IsNullOrWhiteSpace(ViewModel.DxfPreviewPathData))
            {
                <div class="flex flex-1 items-center justify-center">
                    <span class="text-2xl tracking-widest font-headline uppercase opacity-50" style="color: #8b949e;">NO SIGNAL / NO CAD LOADED</span>
                </div>
            }
            else
            {
                <!-- X/Y/Z Readouts Overlay -->
                <div class="absolute top-4 left-4 flex gap-2">
                    <div class="px-3 py-1 border text-[10px] font-mono uppercase" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #8b949e;">X: 0.000</div>
                    <div class="px-3 py-1 border text-[10px] font-mono uppercase" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #8b949e;">Y: 0.000</div>
                    <div class="px-3 py-1 border text-[10px] font-mono uppercase" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #8b949e;">Z: 0.000</div>
                </div>

                <!-- SVG CAD PREVIEW -->
                <div class="absolute inset-0 flex items-center justify-center p-4" @ref="svgContainer" @onwheel="OnMouseWheel" @onwheel:preventDefault="true" @onmousedown="OnMouseDown" @onmousemove="OnMouseMove" @onmouseup="OnMouseUp" @onmouseleave="OnMouseLeave" @onclick="OnSvgClick">
                    <svg viewBox="-5 -5 210 210" class="w-full h-full" preserveAspectRatio="none" style="transform: translate(@(PanX)px, @(PanY)px) scale(@(ZoomLevel)); transform-origin: center; filter: drop-shadow(0 0 8px rgba(0, 229, 255, 0.3));">
                        <g>
                            <path d="@ViewModel.DxfPreviewPathData" stroke="#00e5ff" stroke-width="0.5" fill="none" vector-effect="non-scaling-stroke" />
                            
                            @if (ViewModel.SelectedPointIndex > 0)
                            {
                                var selPt = GetSelectedPointCoords();
                                if (selPt.HasValue)
                                {
                                    double cx = (selPt.Value.X - ViewModel.DxfSvgMinX) * ViewModel.DxfSvgScale;
                                    double cy = 200 - (selPt.Value.Y - ViewModel.DxfSvgMinY) * ViewModel.DxfSvgScale;
                                    <circle cx="@cx" cy="@cy" r="3" fill="#ff3d00" stroke="#ffffff" stroke-width="0.5" vector-effect="non-scaling-stroke" />
                                    <circle cx="@cx" cy="@cy" r="5" fill="none" stroke="#ff3d00" stroke-width="0.3" opacity="0.6" vector-effect="non-scaling-stroke">
                                        <animate attributeName="r" from="3" to="10" dur="1.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" from="0.6" to="0" dur="1.5s" repeatCount="indefinite" />
                                    </circle>
                                }
                            }
                        </g>
                    </svg>
                </div>
                
                <!-- Mini Stats Overlay -->
                <div class="absolute bottom-4 left-4 border px-3 py-2 text-[10px] font-mono uppercase" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #8b949e;">
                    Entities: @ViewModel.DxfEntityCount | Contours: @(ViewModel.DxfContours?.Count ?? 0) | Layers: @ViewModel.DxfLayerCount
                </div>
                
                <!-- Zoom controls overlay -->
                <div class="absolute bottom-4 right-4 flex flex-col gap-2">
                    <button class="w-10 h-10 border flex items-center justify-center transition-colors" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #c9d1d9;" @onclick="() => ZoomIn()" title="Zoom In"><span class="material-symbols-outlined">add</span></button>
                    <button class="w-10 h-10 border flex items-center justify-center transition-colors" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #c9d1d9;" @onclick="() => ZoomOut()" title="Zoom Out"><span class="material-symbols-outlined">remove</span></button>
                    <button class="w-10 h-10 border flex items-center justify-center transition-colors" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #c9d1d9;" @onclick="() => ResetZoomAndPan()" title="Reset View"><span class="material-symbols-outlined">fit_screen</span></button>
                </div>
                
                <!-- Zoom level indicator -->
                <div class="absolute top-4 right-4 border px-3 py-1 text-[10px] font-mono uppercase" style="background: rgba(13,17,23,0.85); border-color: rgba(100,180,200,0.2); color: #8b949e;">
                    Zoom: @(Math.Round(ZoomLevel * 100))% | Pan: (@(Math.Round(PanX)), @(Math.Round(PanY)))
                </div>
            }
        </div>

        <!-- Right Side Tables -->
        <div class="flex-1 flex flex-col gap-6 h-full min-w-[320px]">
            
            <!-- Point Coordinates Table -->
            <div class="flex-[3] flex flex-col bg-surface-container-low border border-outline-variant/20 overflow-hidden">
                <div class="bg-surface-container-highest p-3 border-b border-outline-variant/30 flex justify-between items-center shrink-0">
                    <span class="font-headline font-bold uppercase text-xs tracking-widest">POINT_DATA_SET</span>
                    <span class="text-[10px] text-primary-container font-mono">COUNT: @(GetTotalPointCount())</span>
                </div>
                <div class="flex-1 overflow-auto overflow-x-hidden [scrollbar-width:thin] [scrollbar-color:var(--c-outline-variant)_transparent]">
                    <table class="w-full text-left text-[11px] font-mono border-collapse">
                        <thead class="sticky top-0 bg-surface-container-low z-10 shadow-sm">
                            <tr>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium w-12">STT</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">TYPE</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">X</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">Y</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10">
                            @if (ViewModel.DxfContours != null && ViewModel.DxfContours.Count > 0)
                            {
                                int stt = 1;
                                foreach (var contour in ViewModel.DxfContours)
                                {
                                    if (contour.Points != null && contour.Points.Count > 0)
                                    {
                                        foreach (var pt in contour.Points)
                                        {
                                            int currentStt = stt;
                                            bool isSelected = ViewModel.SelectedPointIndex == currentStt;
                                            string rowBg = isSelected ? "bg-primary/20" : (stt % 2 == 0 ? "bg-surface-container-low" : "bg-surface");
                                            string borderClass = isSelected ? "border-l-4 border-primary" : "";
                                            
                                            <tr class="@rowBg @borderClass h-8 hover:bg-surface-container-high transition-colors cursor-pointer" @onclick="() => SelectPoint(currentStt)">
                                                <td class="p-2 text-outline text-center @(isSelected ? "text-primary font-bold" : "")">@stt.ToString("D4")</td>
                                                <td class="p-2 text-on-surface">@(contour.IsCircle ? "CIRCLE" : (contour.IsArc ? "ARC" : "LINEAR"))</td>
                                                <td class="p-2 text-primary-fixed-dim">@pt.X.ToString("F3")</td>
                                                <td class="p-2 text-primary-fixed-dim">@pt.Y.ToString("F3")</td>
                                            </tr>
                                            stt++;
                                        }
                                    }
                                    @if (contour.HasCenter)
                                    {
                                        int ctrStt = stt;
                                        bool isCtrSelected = ViewModel.SelectedPointIndex == ctrStt;
                                        string ctrBg = isCtrSelected ? "bg-primary/20" : (stt % 2 == 0 ? "bg-surface-container-low" : "bg-surface");
                                        string ctrBorder = isCtrSelected ? "border-l-4 border-primary" : "";
                                        string ctrType = contour.IsCircle ? "CTR_CIR" : "CTR_ARC";
                                        
                                        <tr class="@ctrBg @ctrBorder h-8 hover:bg-surface-container-high transition-colors cursor-pointer" @onclick="() => SelectPoint(ctrStt)">
                                            <td class="p-2 text-outline text-center @(isCtrSelected ? "text-primary font-bold" : "")">@stt.ToString("D4")</td>
                                            <td class="p-2 text-secondary font-bold">@ctrType</td>
                                            <td class="p-2 text-secondary">@contour.CenterX.ToString("F3")</td>
                                            <td class="p-2 text-secondary">@contour.CenterY.ToString("F3")</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Motion Details Table -->
            <div class="flex-[2] flex flex-col bg-surface-container-lowest border border-outline-variant/50 overflow-hidden">
                <div class="bg-surface-container-highest p-3 border-b border-outline-variant/30 flex justify-between items-center shrink-0">
                    <span class="font-headline font-bold uppercase text-xs tracking-widest">MOTION_KERNEL</span>
                    <span class="text-[10px] text-primary-container font-mono">POINTS: @(GetMotionPointCount()) | SPEED: @(ViewModel.DxfDefaultSpeed)um/s</span>
                </div>
                <div class="flex-1 overflow-auto overflow-x-hidden [scrollbar-width:thin] [scrollbar-color:var(--c-outline-variant)_transparent]">
                    <table class="w-full text-left text-[11px] font-mono border-collapse">
                        <thead class="sticky top-0 bg-surface-container-lowest z-10 shadow-sm">
                            <tr>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium w-10">STT</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">CMD</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">M</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">SPEED</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">X(µm)</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">Y(µm)</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">CX(µm)</th>
                                <th class="p-2 border-b border-outline-variant/20 text-outline uppercase font-medium">CY(µm)</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10">
                            @if (ViewModel.DxfContours != null && ViewModel.DxfContours.Count > 0)
                            {
                                int motionIdx = 1;
                                int totalMotionPts = GetMotionPointCount();
                                foreach (var contour in ViewModel.DxfContours)
                                {
                                    if (contour.Points == null || contour.Points.Count < 2) continue;

                                    if (contour.IsCircle)
                                    {
                                        bool isLast = motionIdx == totalMotionPts;
                                        ushort cmd = isLast ? (ushort)0x100F : (ushort)0xD00F;
                                        bool glue = motionIdx >= ViewModel.DxfGlueStartIndex && motionIdx <= ViewModel.DxfGlueEndIndex;
                                        var ep = contour.Points.Last();
                                        string rowBg = motionIdx % 2 == 0 ? "bg-surface-container-lowest" : "bg-surface-container-low";
                                        <tr class="@rowBg h-8 hover:bg-surface-container-high transition-colors">
                                            <td class="p-2 text-outline text-center">@motionIdx</td>
                                            <td class="p-2 text-on-surface font-bold">H@(cmd.ToString("X4"))</td>
                                            <td class="p-2">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-2 h-2 rounded-full @(glue ? "bg-secondary shadow-[0_0_8px_var(--c-secondary)]" : "bg-outline/20")"></div>
                                                    <span class="@(glue ? "text-secondary font-bold" : "text-outline")">@(glue ? "1" : "0")</span>
                                                </div>
                                            </td>
                                            <td class="p-2 text-outline">@ViewModel.DxfDefaultSpeed</td>
                                            <td class="p-2 text-primary-fixed-dim">@((int)(ep.X * 1000))</td>
                                            <td class="p-2 text-primary-fixed-dim">@((int)(ep.Y * 1000))</td>
                                            <td class="p-2 text-secondary">@((int)(contour.CenterX * 1000))</td>
                                            <td class="p-2 text-secondary">@((int)(contour.CenterY * 1000))</td>
                                        </tr>
                                        motionIdx++;
                                    }
                                    else if (contour.IsArc)
                                    {
                                        bool isLast = motionIdx == totalMotionPts;
                                        ushort cmdBase = contour.ArcClockwise ? (ushort)0x000F : (ushort)0x0010;
                                        ushort cmd = isLast ? (ushort)(0x1000 | cmdBase) : (ushort)(0xD000 | cmdBase);
                                        bool glue = motionIdx >= ViewModel.DxfGlueStartIndex && motionIdx <= ViewModel.DxfGlueEndIndex;
                                        var ep = contour.Points.Last();
                                        string rowBg = motionIdx % 2 == 0 ? "bg-surface-container-lowest" : "bg-surface-container-low";
                                        <tr class="@rowBg h-8 hover:bg-surface-container-high transition-colors">
                                            <td class="p-2 text-outline text-center">@motionIdx</td>
                                            <td class="p-2 text-on-surface font-bold">H@(cmd.ToString("X4"))</td>
                                            <td class="p-2">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-2 h-2 rounded-full @(glue ? "bg-secondary shadow-[0_0_8px_var(--c-secondary)]" : "bg-outline/20")"></div>
                                                    <span class="@(glue ? "text-secondary font-bold" : "text-outline")">@(glue ? "1" : "0")</span>
                                                </div>
                                            </td>
                                            <td class="p-2 text-outline">@ViewModel.DxfDefaultSpeed</td>
                                            <td class="p-2 text-primary-fixed-dim">@((int)(ep.X * 1000))</td>
                                            <td class="p-2 text-primary-fixed-dim">@((int)(ep.Y * 1000))</td>
                                            <td class="p-2 text-secondary">@((int)(contour.CenterX * 1000))</td>
                                            <td class="p-2 text-secondary">@((int)(contour.CenterY * 1000))</td>
                                        </tr>
                                        motionIdx++;
                                    }
                                    else
                                    {
                                        for (int i = 1; i < contour.Points.Count; i++)
                                        {
                                            bool isLast = motionIdx == totalMotionPts;
                                            ushort cmd = isLast ? (ushort)0x100A : (ushort)0xD00A;
                                            bool glue = motionIdx >= ViewModel.DxfGlueStartIndex && motionIdx <= ViewModel.DxfGlueEndIndex;
                                            var pt = contour.Points[i];
                                            string rowBg = motionIdx % 2 == 0 ? "bg-surface-container-lowest" : "bg-surface-container-low";
                                            <tr class="@rowBg h-8 hover:bg-surface-container-high transition-colors">
                                                <td class="p-2 text-outline text-center">@motionIdx</td>
                                                <td class="p-2 text-on-surface font-bold">H@(cmd.ToString("X4"))</td>
                                                <td class="p-2">
                                                    <div class="flex items-center gap-2">
                                                        <div class="w-2 h-2 rounded-full @(glue ? "bg-secondary shadow-[0_0_8px_var(--c-secondary)]" : "bg-outline/20")"></div>
                                                        <span class="@(glue ? "text-secondary font-bold" : "text-outline")">@(glue ? "1" : "0")</span>
                                                    </div>
                                                </td>
                                                <td class="p-2 text-outline">@ViewModel.DxfDefaultSpeed</td>
                                                <td class="p-2 text-primary-fixed-dim">@((int)(pt.X * 1000))</td>
                                                <td class="p-2 text-primary-fixed-dim">@((int)(pt.Y * 1000))</td>
                                                <td class="p-2 text-outline">0</td>
                                                <td class="p-2 text-outline">0</td>
                                            </tr>
                                            motionIdx++;
                                        }
                                    }
                                }
                            }
                            else
                            {
                                for (int i = 0; i < 3; i++)
                                {
                                    string rowBg = i % 2 == 1 ? "bg-surface-container-lowest" : "bg-surface-container-low";
                                    <tr class="@rowBg h-8"><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td><td class="p-2"></td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

    <!-- Bottom Controls Area -->
    <div class="h-24 bg-surface-container-highest border border-outline-variant/40 flex items-center justify-between px-6 shrink-0 z-10 relative">
        <!-- Parameters (Left side of footer) -->
        <div class="flex gap-2 flex-wrap h-full py-3 items-center">
            <!-- ĐIỂM Bắt đầu -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-4 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick="SetStartPoint">
                <span class="text-[9px] text-outline">ĐIỂM</span>
                <span>Bắt đầu</span>
                <span class="text-[10px] text-primary font-mono font-bold">@(ViewModel.DxfStartPointIndex > 0 ? $"#{ViewModel.DxfStartPointIndex:D4}" : "---")</span>
            </button>
            <!-- BƠM KEO Bắt đầu -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-4 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick="SetGlueStart">
                <span class="text-[9px] text-outline">BƠM KEO</span>
                <span>Bắt đầu</span>
                <span class="text-[10px] text-secondary font-mono font-bold">@(ViewModel.DxfGlueStartIndex > 0 ? $"#{ViewModel.DxfGlueStartIndex:D4}" : "---")</span>
            </button>
            <!-- BƠM KEO Kết thúc -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-4 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick="SetGlueEnd">
                <span class="text-[9px] text-outline">BƠM KEO</span>
                <span>Kết thúc</span>
                <span class="text-[10px] text-secondary font-mono font-bold">@(ViewModel.DxfGlueEndIndex > 0 ? $"#{ViewModel.DxfGlueEndIndex:D4}" : "---")</span>
            </button>
            <!-- ĐỘ CAO Z Hạ -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-4 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick='() => OpenParamPopup("zdown")'>
                <span class="text-[9px] text-outline">ĐỘ CAO</span>
                <span>Z Hạ</span>
                <span class="text-[10px] text-primary font-mono font-bold">@(ViewModel.DxfZDown.ToString("F1"))mm</span>
            </button>
            <!-- ĐỘ CAO Z An Toàn -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-4 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick='() => OpenParamPopup("zsafe")'>
                <span class="text-[9px] text-outline">ĐỘ CAO</span>
                <span>Z An Toàn</span>
                <span class="text-[10px] text-primary font-mono font-bold">@(ViewModel.DxfZSafe.ToString("F1"))mm</span>
            </button>
            <!-- THIẾT LẬP Tốc độ -->
            <button class="bg-surface-container-low text-on-surface border border-outline-variant/30 h-full px-6 hover:bg-surface-container-high active:bg-surface transition-colors font-headline text-xs uppercase flex flex-col justify-center items-center min-w-[80px]"
                    @onclick='() => OpenParamPopup("speed")'>
                <span class="text-[9px] text-outline">THIẾT LẬP</span>
                <span>Tốc độ</span>
                <span class="text-[10px] text-primary font-mono font-bold">@(ViewModel.DxfDefaultSpeed)um/s</span>
            </button>
        </div>

        <!-- Actions (Right side of footer) -->
        <div class="flex gap-4">
            <button class="px-6 py-3 border font-headline font-black text-xs flex items-center gap-2 transition-colors uppercase
                @(ViewModel.IsDxfPaused ? "border-secondary text-secondary hover:bg-secondary/10" : "border-primary-container text-primary-container hover:bg-primary-container/10")"
                    @onclick="ResumeClick" disabled="@(!ViewModel.IsDxfPaused)">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">replay</span>
                RESUME
            </button>
            <button class="px-6 py-3 bg-error-container/30 border border-error text-error font-headline font-black text-xs flex items-center gap-2 hover:bg-error-container/50 transition-colors uppercase"
                    @onclick="PauseClick" disabled="@(!ViewModel.IsDxfRunning || ViewModel.IsDxfPaused)">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">pause</span>
                PAUSE
            </button>
            <button class="px-8 py-3 bg-primary-container text-on-primary-fixed font-headline font-black text-xs flex items-center gap-2 hover:bg-primary-fixed-dim transition-colors uppercase shadow-[0_0_15px_rgba(0,240,255,0.2)]"
                    @onclick="StartClick" disabled="@(ViewModel.IsDxfRunning)">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                START_NODE
            </button>
        </div>

        <!-- Inline Parameter Popup -->
        @if (!string.IsNullOrEmpty(paramPopupType))
        {
            <div class="absolute bottom-full left-0 mb-2 ml-4 bg-surface-container-highest border border-primary/50 shadow-2xl p-4 z-50 flex flex-col gap-3 min-w-[280px]"
                 style="box-shadow: 0 0 20px rgba(0,229,255,0.15);">
                <div class="flex justify-between items-center">
                    <span class="font-headline font-bold text-xs uppercase tracking-widest text-on-surface">@GetPopupTitle()</span>
                    <button class="text-outline hover:text-error transition-colors" @onclick="CloseParamPopup">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                </div>
                <div class="flex gap-2 items-center">
                    <input type="number" step="any" class="flex-1 bg-surface-container-low border border-outline-variant/50 text-on-surface px-3 py-2 text-sm font-mono focus:border-primary focus:outline-none"
                           @bind="paramPopupValue" @bind:event="oninput" />
                    <span class="text-outline text-xs font-mono">@GetPopupUnit()</span>
                </div>
                <div class="flex gap-2 justify-end">
                    <button class="px-4 py-2 border border-outline-variant/30 text-outline text-xs font-headline uppercase hover:bg-surface-container-high transition-colors"
                            @onclick="CloseParamPopup">HỦY</button>
                    <button class="px-4 py-2 bg-primary-container text-on-primary-fixed text-xs font-headline font-bold uppercase hover:bg-primary-fixed-dim transition-colors"
                            @onclick="ApplyParamPopup">ÁP DỤNG</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private ElementReference svgContainer;
    private double ZoomLevel = 1.0;
    private double PanX = 0;
    private double PanY = 0;
    private bool isMiddleMouseDown = false;
    private double lastMouseX = 0;
    private double lastMouseY = 0;
    private const double ZoomStep = 0.2;
    private const double MinZoom = 0.1;
    private const double MaxZoom = 5.0;

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += (_, _) => InvokeAsync(StateHasChanged);
        base.OnInitialized();
    }

    private async Task OnMouseWheel(WheelEventArgs e)
    {
        double zoomChange = e.DeltaY > 0 ? -ZoomStep : ZoomStep;
        double newZoom = Math.Clamp(ZoomLevel + zoomChange, MinZoom, MaxZoom);
        if (newZoom != ZoomLevel)
        {
            ZoomLevel = newZoom;
            ViewModel.AddLog("UI", "info", $"Zoomed to {Math.Round(ZoomLevel * 100)}%");
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        if (e.Button == 1) // Middle mouse button
        {
            isMiddleMouseDown = true;
            lastMouseX = e.ClientX;
            lastMouseY = e.ClientY;
        }
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (isMiddleMouseDown)
        {
            double deltaX = e.ClientX - lastMouseX;
            double deltaY = e.ClientY - lastMouseY;
            PanX += deltaX;
            PanY += deltaY;
            lastMouseX = e.ClientX;
            lastMouseY = e.ClientY;
        }
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        if (e.Button == 1)
        {
            isMiddleMouseDown = false;
        }
    }

    private void OnMouseLeave()
    {
        isMiddleMouseDown = false;
    }

    private void ZoomIn()
    {
        ZoomLevel = Math.Clamp(ZoomLevel + ZoomStep, MinZoom, MaxZoom);
        ViewModel.AddLog("UI", "info", $"Zoomed in to {Math.Round(ZoomLevel * 100)}%");
    }

    private void ZoomOut()
    {
        ZoomLevel = Math.Clamp(ZoomLevel - ZoomStep, MinZoom, MaxZoom);
        ViewModel.AddLog("UI", "info", $"Zoomed out to {Math.Round(ZoomLevel * 100)}%");
    }

    private void ResetZoomAndPan()
    {
        ZoomLevel = 1.0;
        PanX = 0;
        PanY = 0;
        ViewModel.AddLog("UI", "info", "Reset zoom and pan to default");
    }

    // --- Parameter Popup State ---
    private string paramPopupType = "";
    private double paramPopupValue;

    private void OpenParamPopup(string type)
    {
        paramPopupType = type;
        paramPopupValue = type switch
        {
            "zdown" => ViewModel.DxfZDown,
            "zsafe" => ViewModel.DxfZSafe,
            "speed" => ViewModel.DxfDefaultSpeed,
            _ => 0
        };
    }

    private void CloseParamPopup() => paramPopupType = "";

    private string GetPopupTitle() => paramPopupType switch
    {
        "zdown" => "ĐỘ CAO Z HẠ",
        "zsafe" => "ĐỘ CAO Z AN TOÀN",
        "speed" => "THIẾT LẬP TỐC ĐỘ",
        _ => ""
    };

    private string GetPopupUnit() => paramPopupType switch
    {
        "zdown" => "mm",
        "zsafe" => "mm",
        "speed" => "um/s",
        _ => ""
    };

    private void ApplyParamPopup()
    {
        switch (paramPopupType)
        {
            case "zdown":
                ViewModel.DxfZDown = paramPopupValue;
                ViewModel.AddLog("UI", "success", $"Z Hạ = {paramPopupValue:F1} mm");
                break;
            case "zsafe":
                ViewModel.DxfZSafe = paramPopupValue;
                ViewModel.AddLog("UI", "success", $"Z An toàn = {paramPopupValue:F1} mm");
                break;
            case "speed":
                ViewModel.DxfDefaultSpeed = (uint)Math.Max(1, paramPopupValue);
                ViewModel.AddLog("UI", "success", $"Tốc độ = {ViewModel.DxfDefaultSpeed} um/s");
                break;
        }
        paramPopupType = "";
    }

    // --- Point Assignment ---
    private void SetStartPoint()
    {
        if (ViewModel.SelectedPointIndex > 0)
        {
            ViewModel.DxfStartPointIndex = ViewModel.SelectedPointIndex;
            ViewModel.AddLog("UI", "success", $"Điểm bắt đầu = #{ViewModel.DxfStartPointIndex:D4}");
        }
        else
        {
            ViewModel.AddLog("UI", "warning", "Chọn 1 điểm trong bảng trước khi gán.");
        }
    }

    private void SetGlueStart()
    {
        if (ViewModel.SelectedPointIndex > 0)
        {
            ViewModel.DxfGlueStartIndex = ViewModel.SelectedPointIndex;
            ViewModel.AddLog("UI", "success", $"Bơm keo bắt đầu = #{ViewModel.DxfGlueStartIndex:D4}");
        }
        else
        {
            ViewModel.AddLog("UI", "warning", "Chọn 1 điểm trong bảng trước khi gán.");
        }
    }

    private void SetGlueEnd()
    {
        if (ViewModel.SelectedPointIndex > 0)
        {
            ViewModel.DxfGlueEndIndex = ViewModel.SelectedPointIndex;
            ViewModel.AddLog("UI", "success", $"Bơm keo kết thúc = #{ViewModel.DxfGlueEndIndex:D4}");
        }
        else
        {
            ViewModel.AddLog("UI", "warning", "Chọn 1 điểm trong bảng trước khi gán.");
        }
    }

    // --- Action Buttons ---
    private void StartClick()
    {
        if (ViewModel.DxfContours == null || ViewModel.DxfContours.Count == 0)
        {
            ViewModel.AddLog("UI", "warning", "Chưa nạp file DXF.");
            return;
        }
        ViewModel.AddLog("UI", "info", $"Start DXF | Speed={ViewModel.DxfDefaultSpeed} | ZDown={ViewModel.DxfZDown:F1} | ZSafe={ViewModel.DxfZSafe:F1} | StartPt=#{ViewModel.DxfStartPointIndex}");
        ViewModel.IsDxfRunning = true;
        ViewModel.IsDxfPaused = false;
        ViewModel.DownloadTrajectoryToPlc();
    }

    private void PauseClick()
    {
        ViewModel.IsDxfPaused = true;
        ViewModel.AddLog("UI", "warning", "DXF Run PAUSED");
    }

    private void ResumeClick()
    {
        ViewModel.IsDxfPaused = false;
        ViewModel.AddLog("UI", "info", "DXF Run RESUMED");
    }

    private void SelectPoint(int stt)
    {
        ViewModel.SelectedPointIndex = stt;
        var pt = GetSelectedPointCoords();
        if (pt.HasValue)
        {
            ViewModel.AddLog("UI", "info", $"Selected Point #{stt}: ({pt.Value.X:F3}, {pt.Value.Y:F3})");
        }
    }

    private (double X, double Y)? GetSelectedPointCoords()
    {
        if (ViewModel.SelectedPointIndex <= 0 || ViewModel.DxfContours == null) return null;
        int stt = 1;
        foreach (var contour in ViewModel.DxfContours)
        {
            if (contour.Points != null)
            {
                foreach (var pt in contour.Points)
                {
                    if (stt == ViewModel.SelectedPointIndex) return pt;
                    stt++;
                }
            }
            if (contour.HasCenter)
            {
                if (stt == ViewModel.SelectedPointIndex) return (contour.CenterX, contour.CenterY);
                stt++;
            }
        }
        return null;
    }

    private int GetTotalPointCount()
    {
        if (ViewModel.DxfContours == null) return 0;
        int count = 0;
        foreach (var c in ViewModel.DxfContours)
        {
            count += c.Points?.Count ?? 0;
            if (c.HasCenter) count++;
        }
        return count;
    }

    private int GetMotionPointCount()
    {
        if (ViewModel.DxfContours == null) return 0;
        int count = 0;
        foreach (var c in ViewModel.DxfContours)
        {
            if (c.Points == null || c.Points.Count < 2) continue;
            if (c.IsCircle || c.IsArc)
                count++;
            else
                count += c.Points.Count - 1; // Linear: skip first point
        }
        return count;
    }

    private async Task OnSvgClick(MouseEventArgs e)
    {
        if (isMiddleMouseDown) return;
        if (ViewModel.DxfContours == null || !ViewModel.DxfContours.Any()) return;

        try
        {
            // 1. Get container bounds using JS
            var rect = await JSRuntime.InvokeAsync<BoundingClientRect>("getBoundingClientRect", svgContainer);
            if (rect == null) return;

            // 2. Calculate coordinates relative to the container center (since transform-origin is center)
            double centerX = rect.Left + rect.Width / 2;
            double centerY = rect.Top + rect.Height / 2;

            // 3. Reverse Pan and Zoom
            double relativeX = (e.ClientX - centerX - PanX) / ZoomLevel;
            double relativeY = (e.ClientY - centerY - PanY) / ZoomLevel;

            // 4. Map back to 0-200 SVG coordinate space
            // The SVG is centered and preserved aspect ratio 'none', so it fills the container.
            double svgX = (relativeX / (rect.Width / 2)) * 100 + 100;
            double svgY = (relativeY / (rect.Height / 2)) * 100 + 100;

            // 5. Map back to DXF coordinate space
            double dxfX = (svgX / ViewModel.DxfSvgScale) + ViewModel.DxfSvgMinX;
            double dxfY = ((200 - svgY) / ViewModel.DxfSvgScale) + ViewModel.DxfSvgMinY;

            // 6. Find the nearest point
            double minDistanceSq = double.MaxValue;
            int nearestStt = -1;
            int stt = 1;

            foreach (var contour in ViewModel.DxfContours)
            {
                if (contour.Points != null)
                {
                    foreach (var pt in contour.Points)
                    {
                        double dx = pt.X - dxfX;
                        double dy = pt.Y - dxfY;
                        double distSq = dx * dx + dy * dy;
                        if (distSq < minDistanceSq)
                        {
                            minDistanceSq = distSq;
                            nearestStt = stt;
                        }
                        stt++;
                    }
                }
                if (contour.HasCenter)
                {
                    double dx = contour.CenterX - dxfX;
                    double dy = contour.CenterY - dxfY;
                    double distSq = dx * dx + dy * dy;
                    if (distSq < minDistanceSq)
                    {
                        minDistanceSq = distSq;
                        nearestStt = stt;
                    }
                    stt++;
                }
            }

            // 7. Select if close enough (e.g., within 5 units in DXF space)
            if (nearestStt != -1)
            {
                SelectPoint(nearestStt);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SvgClick error: {ex.Message}");
        }
    }

    public class BoundingClientRect
    {
        public double Top { get; set; }
        public double Left { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }
}
