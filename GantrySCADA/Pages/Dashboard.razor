@page "/"
@inject WPF_Test_PLC20260124.MainViewModel ViewModel

<div class="grid grid-cols-12 gap-8">
    <!-- Connection & Settings Section (Asymmetric Left) -->
    <section class="col-span-12 lg:col-span-4 space-y-8">
        <div class="bg-surface-container-low p-8 rounded-lg space-y-6">
            <div class="flex justify-between items-center">
                <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant">System Connectivity</h2>
                <div class="flex items-center gap-2 px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm">
                    @if (ViewModel.Status)
                    {
                        <span class="w-1.5 h-1.5 bg-secondary rounded-full animate-pulse"></span>
                        <span>Connected</span>
                    }
                    else
                    {
                        <span class="w-1.5 h-1.5 bg-tertiary rounded-full"></span>
                        <span>Disconnected</span>
                    }
                </div>
            </div>
            <div class="space-y-4">
                <div class="space-y-1.5">
                    <label class="font-label text-[10px] font-bold uppercase tracking-[0.05em] text-outline">PLC IP Address</label>
                    <input class="w-full bg-surface-container-highest border-none focus:ring-2 focus:ring-primary/20 text-on-surface font-body text-sm px-4 py-3 rounded-lg placeholder-outline" type="text" @bind="ViewModel.IpAddress" />
                </div>
                <div class="space-y-1.5">
                    <label class="font-label text-[10px] font-bold uppercase tracking-[0.05em] text-outline">PLC Port</label>
                    <input class="w-full bg-surface-container-highest border-none focus:ring-2 focus:ring-primary/20 text-on-surface font-body text-sm px-4 py-3 rounded-lg placeholder-outline" type="number" @bind="ViewModel.Port" />
                </div>
                <div class="grid grid-cols-2 gap-3 pt-2">
                    <button class="bg-gradient-to-r from-primary to-primary-container text-on-primary font-label text-xs font-bold uppercase tracking-wider py-3 rounded-lg hover:shadow-lg transition-all" @onclick="Connect">
                        Connect
                    </button>
                    <button class="border border-outline-variant text-primary font-label text-xs font-bold uppercase tracking-wider py-3 rounded-lg hover:bg-surface-container-high transition-all" @onclick="Disconnect">
                        Disconnect
                    </button>
                </div>
            </div>
        </div>

        <!-- Write Section: Control Input -->
        <div class="bg-surface-container-lowest p-8 rounded-lg shadow-sm space-y-6">
            <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant">Manual Kinematic Jog</h2>

            <!-- Removed Target Position as requested, retaining Jog matrix -->
            <div class="flex justify-center my-6">
                <div class="relative bg-surface-container-low p-6 rounded-2xl shadow-inner inline-flex flex-col gap-4">
                    <!-- Target Grid Background -->
                    <div class="absolute inset-0 max-w-full m-auto w-32 h-32 border border-outline-variant/30 rounded-full opacity-50 flex items-center justify-center">
                        <div class="absolute w-full h-px bg-outline-variant/30"></div>
                        <div class="absolute h-full w-px bg-outline-variant/30"></div>
                    </div>
                    
                    <div class="grid grid-cols-3 gap-2 text-center items-center relative z-10 mx-auto">
                        <div></div>
                        <button class="bg-white hover:bg-surface-container-highest active:bg-primary/10 text-on-surface border border-outline-variant/50 p-4 rounded-xl shadow-sm transition-all flex justify-center items-center" @onmousedown="() => Jog('Y', false)" @onmouseup="() => StopJog('Y')">
                            <span class="material-symbols-outlined">arrow_upward</span>
                        </button>
                        <div></div>
                        
                        <button class="bg-white hover:bg-surface-container-highest active:bg-primary/10 text-on-surface border border-outline-variant/50 p-4 rounded-xl shadow-sm transition-all flex justify-center items-center" @onmousedown="() => Jog('X', false)" @onmouseup="() => StopJog('X')">
                            <span class="material-symbols-outlined">arrow_back</span>
                        </button>
                        <div class="text-[10px] font-label font-bold text-outline tracking-wider">XY</div>
                        <button class="bg-white hover:bg-surface-container-highest active:bg-primary/10 text-on-surface border border-outline-variant/50 p-4 rounded-xl shadow-sm transition-all flex justify-center items-center" @onmousedown="() => Jog('X', true)" @onmouseup="() => StopJog('X')">
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </button>
                        
                        <div></div>
                        <button class="bg-white hover:bg-surface-container-highest active:bg-primary/10 text-on-surface border border-outline-variant/50 p-4 rounded-xl shadow-sm transition-all flex justify-center items-center" @onmousedown="() => Jog('Y', true)" @onmouseup="() => StopJog('Y')">
                            <span class="material-symbols-outlined">arrow_downward</span>
                        </button>
                        <div></div>
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-3 pt-4">
                <button class="flex items-center justify-center gap-2 bg-secondary text-white font-label text-xs font-bold uppercase tracking-wider py-4 rounded-lg hover:brightness-110 transition-all group" @onmousedown="() => Jog('Z', false)" @onmouseup="() => StopJog('Z')">
                    <span class="material-symbols-outlined text-sm group-active:-translate-y-1 transition-transform">arrow_upward</span> Z+ (UP)
                </button>
                <button class="flex items-center justify-center gap-2 bg-surface-variant text-on-surface font-label text-xs font-bold uppercase tracking-wider py-4 rounded-lg hover:brightness-90 transition-all group" @onmousedown="() => Jog('Z', true)" @onmouseup="() => StopJog('Z')">
                    <span class="material-symbols-outlined text-sm group-active:translate-y-1 transition-transform">arrow_downward</span> Z- (DN)
                </button>
            </div>
        </div>
    </section>

    <!-- Read Section: Data & Telemetry (Asymmetric Right) -->
    <section class="col-span-12 lg:col-span-8 space-y-8">
        <!-- Data Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Card X -->
            <div class="bg-surface-container-lowest p-6 rounded-lg relative overflow-hidden shadow-sm flex flex-col justify-between h-32 group hover:shadow transition-shadow">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                <label class="font-body text-[10px] font-semibold text-outline uppercase tracking-wider">Position X</label>
                <div class="flex items-baseline gap-1">
                    <span class="font-headline text-4xl font-bold text-on-surface group-hover:text-primary transition-colors">@(ViewModel.arr_R32.Length > 0 ? ViewModel.arr_R32[0] : 0)</span>
                    <span class="font-headline text-sm text-outline">mm</span>
                </div>
            </div>
            <!-- Card Y -->
            <div class="bg-surface-container-lowest p-6 rounded-lg relative overflow-hidden shadow-sm flex flex-col justify-between h-32 group hover:shadow transition-shadow">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                <label class="font-body text-[10px] font-semibold text-outline uppercase tracking-wider">Position Y</label>
                <div class="flex items-baseline gap-1">
                    <span class="font-headline text-4xl font-bold text-on-surface group-hover:text-primary transition-colors">@(ViewModel.arr_R32.Length > 1 ? ViewModel.arr_R32[1] : 0)</span>
                    <span class="font-headline text-sm text-outline">mm</span>
                </div>
            </div>
            <!-- Card Z -->
            <div class="bg-surface-container-lowest p-6 rounded-lg relative overflow-hidden shadow-sm flex flex-col justify-between h-32 group hover:shadow transition-shadow">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                <label class="font-body text-[10px] font-semibold text-outline uppercase tracking-wider">Position Z</label>
                <div class="flex items-baseline gap-1">
                    <span class="font-headline text-4xl font-bold text-on-surface group-hover:text-primary transition-colors">@(ViewModel.arr_R32.Length > 2 ? ViewModel.arr_R32[2] : 0)</span>
                    <span class="font-headline text-sm text-outline">mm</span>
                </div>
            </div>
            <!-- Velocity -->
            <div class="md:col-span-2 bg-surface-container-lowest p-6 rounded-lg relative overflow-hidden shadow-sm flex items-center justify-between">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                <div class="space-y-1">
                    <label class="font-body text-[10px] font-semibold text-outline uppercase tracking-wider">Target Velocity</label>
                    <div class="flex items-baseline gap-1">
                        <span class="font-headline text-4xl font-bold text-on-surface">@VelocityVal</span>
                        <span class="font-headline text-sm text-outline">m/s</span>
                    </div>
                </div>
                <div class="flex flex-col gap-2 w-1/2 mt-4 px-4">
                    <input class="w-full h-1.5 bg-surface-dim rounded-full appearance-none cursor-pointer accent-primary" type="range" min="0" max="5.0" step="0.1" @bind="VelocityVal" @bind:event="oninput" />
                    <div class="flex justify-between text-[10px] font-label font-bold text-outline uppercase mt-2">
                        <span>0.0</span>
                        <span>5.0</span>
                    </div>
                </div>
            </div>
            <!-- State -->
            <div class="bg-surface-container-low p-6 rounded-lg flex flex-col justify-center items-center gap-2 shadow-sm border border-outline-variant/20">
                <span class="font-label text-[10px] font-bold text-outline uppercase">System State</span>
                <div class="flex items-center gap-2 @(ViewModel.Status ? "text-secondary" : "text-tertiary")">
                    <span class="material-symbols-outlined text-3xl">@(ViewModel.Status ? "motion_photos_on" : "motion_photos_paused")</span>
                    <span class="font-headline text-2xl font-bold">@(ViewModel.Status ? "RUNNING" : "STOPPED")</span>
                </div>
            </div>
        </div>

        <!-- Recent Logs Section transformed into Memory Stream Debugger -->
        <div class="bg-surface-container-lowest rounded-lg overflow-hidden shadow-sm border border-outline-variant/20">
            <div class="px-8 py-6 flex justify-between items-center border-b border-surface-variant/30">
                <div class="flex items-center gap-2">
                   <h2 class="font-label text-xs font-bold uppercase tracking-[0.05em] text-on-surface-variant flex items-center gap-2">
                       Real-Time Memory Stream
                   </h2>
                   <div class="flex gap-1 pl-4">
                       <div class="w-1.5 h-1.5 rounded-full bg-outline-variant animate-pulse delay-75"></div>
                       <div class="w-1.5 h-1.5 rounded-full bg-outline-variant animate-pulse delay-150"></div>
                       <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse delay-300"></div>
                   </div>
                </div>
                <span class="text-[10px] font-mono text-outline uppercase tracking-wider">BASE: D_@ViewModel.D_R_V</span>
            </div>
            
            <div class="p-6 bg-surface-container-lowest">
               <div class="bg-inverse-surface rounded-lg p-5 h-64 overflow-y-auto shadow-inner relative z-0">
                   <div class="absolute top-0 left-0 w-full h-10 bg-gradient-to-b from-inverse-surface to-transparent pointer-events-none z-10"></div>
                   <div class="absolute bottom-0 left-0 w-full h-10 bg-gradient-to-t from-inverse-surface to-transparent pointer-events-none z-10"></div>
                   
                   <div class="text-sm font-mono space-y-1 relative z-0 pb-4">
                       @if(ViewModel.arr_R_V != null && ViewModel.arr_R_V.Length > 0)
                       {
                           @for (int i = 0; i < Math.Min(10, ViewModel.arr_R_V.Length); i++)
                           {
                               <div class="flex justify-between py-2 border-b border-inverse-on-surface/10 hover:bg-inverse-on-surface/10 px-3 rounded transition-colors group">
                                   <span class="text-outline-variant group-hover:text-inverse-on-surface">D<span class="font-bold">@(ViewModel.D_R_V + i)</span></span>
                                   <span class="text-primary-fixed-dim font-bold flex items-center gap-2">
                                       <span class="text-outline text-[10px] font-normal tracking-wide">VAL</span>
                                       @ViewModel.arr_R_V[i]
                                   </span>
                               </div>
                           }
                       }
                       else
                       {
                           <div class="flex flex-col items-center justify-center min-h-[12rem] text-outline gap-3">
                               <span class="material-symbols-outlined text-4xl animate-spin">refresh</span>
                               <span class="font-label text-xs uppercase tracking-widest">Awaiting stream...</span>
                           </div>
                       }
                   </div>
               </div>
            </div>
        </div>
    </section>
</div>

@code {
    private double VelocityVal = 1.5;
    private Dictionary<char, int> LastActiveMark = new() { { 'X', -1 }, { 'Y', -1 }, { 'Z', -1 } };

    protected override void OnInitialized()
    {
        ViewModel.AddLog("UI", "info", "Dashboard page loaded");
        base.OnInitialized();
    }

    private void Connect()
    {
        if(!ViewModel.Status)
        {
            ViewModel.AddLog("UI", "info", "User clicked [Connect PLC]");
            ViewModel.ConnectCommand.Execute(null);
        }
    }

    private void Disconnect()
    {
        if(ViewModel.Status)
        {
            ViewModel.AddLog("UI", "info", "User clicked [Disconnect]");
            ViewModel.DisconnectCommand.Execute(null);
        }
    }

    private void Jog(char axis, bool dir)
    {
        // Map axis + direction to mark address
        // X+ (false) = m3000, X- (true) = m3001
        // Y+ (false) = m3002, Y- (true) = m3003
        // Z+ (false) = m3004, Z- (true) = m3005
        int markAddress = axis switch
        {
            'X' => dir ? 3001 : 3000,
            'Y' => dir ? 3003 : 3002,
            'Z' => dir ? 3005 : 3004,
            _ => -1
        };
        
        if (markAddress >= 0)
        {
            string dirName = (axis, dir) switch
            {
                ('X', false) => "X+", ('X', true) => "X-",
                ('Y', false) => "Y+", ('Y', true) => "Y-",
                ('Z', false) => "Z+", ('Z', true) => "Z-",
                _ => "?"
            };
            ViewModel.AddLog("UI", "info", $"Jog {dirName} pressed");
            LastActiveMark[axis] = markAddress;
            ViewModel.JogStart(markAddress);
        }
    }
    private void StopJog(char axis)
    {
        // Stop all jog marks for this axis
        ViewModel.AddLog("UI", "info", $"Jog {axis} released");
        switch (axis)
        {
            case 'X':
                ViewModel.JogStop(3000);
                ViewModel.JogStop(3001);
                break;
            case 'Y':
                ViewModel.JogStop(3002);
                ViewModel.JogStop(3003);
                break;
            case 'Z':
                ViewModel.JogStop(3004);
                ViewModel.JogStop(3005);
                break;
        }
        LastActiveMark[axis] = -1;
    }
}
