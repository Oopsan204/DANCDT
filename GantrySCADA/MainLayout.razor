@inherits LayoutComponentBase
@inject WPF_Test_PLC20260124.MainViewModel ViewModel
@inject IJSRuntime JS

<div class="bg-background text-on-background font-body min-h-screen">
    <!-- TopNavBar -->
    <nav style="background: var(--nav-bg); border-bottom: 1px solid var(--border-color);"
         class="fixed top-0 w-full z-50 flex justify-between items-center px-8 h-16 max-w-[1920px] mx-auto shadow-sm">
        <div class="flex items-center gap-8">
            <span class="text-lg font-bold tracking-tighter text-primary">PRECISION SCADA</span>
            <div class="hidden md:flex gap-6">
                <NavLink href="/" Match="NavLinkMatch.All" class="text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" ActiveClass="text-primary border-b-2 border-primary">Dashboard</NavLink>
                <NavLink href="/logmonitor" class="text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" ActiveClass="text-primary border-b-2 border-primary">Logs</NavLink>
                <NavLink href="/telemetry" class="text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" ActiveClass="text-primary border-b-2 border-primary">Telemetry</NavLink>
                <NavLink href="/settings" class="text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" ActiveClass="text-primary border-b-2 border-primary">System Settings</NavLink>
                <NavLink href="/dxf-run" class="text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" ActiveClass="text-primary border-b-2 border-primary">DXF Run</NavLink>
            </div>

        </div>
        <div class="flex items-center gap-3">
            <!-- ✦ Theme Toggle Button -->
            <button id="theme-toggle" @onclick="ToggleTheme" title="Toggle dark / light mode">
                <span class="material-symbols-outlined" style="font-size:18px;">
                    @(isDark ? "light_mode" : "dark_mode")
                </span>
            </button>
            <button class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                <span class="material-symbols-outlined">notifications</span>
            </button>
            <button class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                <span class="material-symbols-outlined">account_circle</span>
            </button>
        </div>
    </nav>

    <!-- SideNavBar -->
    <aside style="background: var(--sidebar-bg); border-right: 1px solid var(--border-color);"
           class="fixed left-0 top-16 h-[calc(100vh-64px)] w-64 flex flex-col py-6 gap-2 shadow-sm z-40">
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded bg-surface-container-high flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
                </div>
                <div>
                    <h3 class="text-sm font-semibold font-body text-on-surface">Unit 01</h3>
                    <p class="text-xs text-on-surface-variant font-body">PLC-Gantry-Alpha</p>
                </div>
            </div>
        </div>
        <nav class="flex-grow space-y-1">
            <NavLink href="/" Match="NavLinkMatch.All" class="flex items-center gap-3 px-6 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" ActiveClass="bg-surface-container-lowest text-primary border-l-4 border-primary shadow-sm">
                <span class="material-symbols-outlined text-lg">precision_manufacturing</span> Control
            </NavLink>
            <NavLink href="/telemetry" class="flex items-center gap-3 px-6 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" ActiveClass="bg-surface-container-lowest text-primary border-l-4 border-primary shadow-sm">
                <span class="material-symbols-outlined text-lg">analytics</span> Telemetry
            </NavLink>
            <NavLink href="/logmonitor" class="flex items-center gap-3 px-6 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" ActiveClass="bg-surface-container-lowest text-primary border-l-4 border-primary shadow-sm">
                <span class="material-symbols-outlined text-lg">feed</span> Logs
            </NavLink>
            <NavLink href="/settings" class="flex items-center gap-3 px-6 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" ActiveClass="bg-surface-container-lowest text-primary border-l-4 border-primary shadow-sm">
                <span class="material-symbols-outlined text-lg">settings</span> Settings
            </NavLink>
            <NavLink href="/dxf-run" class="flex items-center gap-3 px-6 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" ActiveClass="bg-surface-container-lowest text-primary border-l-4 border-primary shadow-sm">
                <span class="material-symbols-outlined text-lg">data_object</span> DXF Run
            </NavLink>
        </nav>

        <div class="px-6 mt-auto flex flex-col gap-4">
            <button class="w-full py-3 bg-tertiary text-white font-label font-bold text-xs uppercase tracking-wider rounded-lg hover:brightness-110 transition-all">
                EMERGENCY STOP
            </button>
            <div class="space-y-1 pt-4" style="border-top: 1px solid var(--border-color);">
                <a class="flex items-center gap-3 py-2 text-on-surface-variant hover:text-primary transition-colors font-label text-xs font-bold uppercase" href="#">
                    <span class="material-symbols-outlined text-lg">help</span> Support
                </a>
                <a class="flex items-center gap-3 py-2 text-on-surface-variant hover:text-tertiary transition-colors font-label text-xs font-bold uppercase" href="#">
                    <span class="material-symbols-outlined text-lg">logout</span> Logout
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content Canvas -->
    <main class="ml-[16rem] pt-24 p-8 max-w-[1600px] mx-auto min-h-screen">
        @Body
    </main>

    <!-- Gantry Progress Rail -->
    <div class="fixed bottom-0 left-[16rem] right-0 h-1.5 z-40" style="background: var(--c-surface-container-high, #1a2440);">
        <div class="bg-primary h-full transition-all duration-1000"
             style="width: @(Math.Min(100, Math.Max(0, (ViewModel.arr_R32.Length > 0 ? ViewModel.arr_R32[0] : 0) / 20.0)))%;">
        </div>
        <div class="absolute -top-6 -translate-x-1/2 flex flex-col items-center transition-all duration-1000"
             style="left: @(Math.Min(100, Math.Max(0, (ViewModel.arr_R32.Length > 0 ? ViewModel.arr_R32[0] : 0) / 20.0)))%;">
            <span class="text-[8px] font-bold font-label text-primary uppercase bg-surface-container-lowest/80 px-1 rounded shadow-sm">
                Current Head Position
            </span>
            <div class="w-px h-6 bg-primary"></div>
        </div>
    </div>

    <!-- ✦ Dark Mode Floating Indicator (shows current mode) -->
    <div class="fixed bottom-4 right-4 z-50 flex items-center gap-2 px-3 py-2 rounded-lg shadow-lg
                bg-surface-container-lowest border border-outline-variant/30 text-on-surface-variant
                font-label text-[10px] uppercase tracking-wider pointer-events-none"
         style="font-family:'Space Grotesk',sans-serif; font-weight:700;">
        <span class="material-symbols-outlined" style="font-size:13px;">@(isDark ? "dark_mode" : "light_mode")</span>
        @(isDark ? "Dark Mode" : "Light Mode")
    </div>
</div>

@code {
    bool isDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ViewModel.PropertyChanged += (sender, e) => InvokeAsync(StateHasChanged);
            var theme = await JS.InvokeAsync<string>("getTheme");
            isDark = theme == "dark";
            StateHasChanged();
        }
    }

    async Task ToggleTheme()
    {
        isDark = await JS.InvokeAsync<bool>("toggleTheme");
        StateHasChanged();
    }
}
