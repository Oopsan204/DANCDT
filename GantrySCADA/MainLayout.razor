@inherits LayoutComponentBase
@inject WPF_Test_PLC20260124.MainViewModel ViewModel

<div class="bg-background text-on-background font-body min-h-screen">
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 bg-slate-50 flex justify-between items-center px-8 h-16 w-full max-w-[1920px] mx-auto border-b border-surface-variant/20 shadow-sm">
        <div class="flex items-center gap-8">
            <span class="text-lg font-bold tracking-tighter text-primary">PRECISION SCADA</span>
            <div class="hidden md:flex gap-6">
                <a class="text-primary border-b-2 border-primary font-label text-xs uppercase tracking-[0.05em] py-5" href="#">Dashboard</a>
                <a class="text-slate-500 hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" href="#">Logs</a>
                <a class="text-slate-500 hover:text-primary transition-colors font-label text-xs uppercase tracking-[0.05em] py-5" href="#">System Settings</a>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <button class="p-2 text-slate-500 hover:text-primary transition-colors"><span class="material-symbols-outlined">notifications</span></button>
            <button class="p-2 text-slate-500 hover:text-primary transition-colors"><span class="material-symbols-outlined">account_circle</span></button>
        </div>
    </nav>

    <!-- SideNavBar -->
    <aside class="fixed left-0 top-16 h-[calc(100vh-64px)] w-64 bg-slate-100 flex flex-col py-6 gap-2 border-r border-surface-variant/20 shadow-sm z-40">
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded bg-surface-container-high flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
                </div>
                <div>
                    <h3 class="text-sm font-semibold font-body">Unit 01</h3>
                    <p class="text-xs text-on-surface-variant font-body">PLC-Gantry-Alpha</p>
                </div>
            </div>
        </div>
        <nav class="flex-grow space-y-1">
            <a class="flex items-center gap-3 px-6 py-3 bg-white text-primary border-l-4 border-primary font-label text-xs font-bold uppercase tracking-[0.05em] shadow-sm" href="#">
                <span class="material-symbols-outlined text-lg" data-icon="precision_manufacturing">precision_manufacturing</span> Control
            </a>
            <a class="flex items-center gap-3 px-6 py-3 text-slate-500 hover:bg-slate-200 transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" href="#">
                <span class="material-symbols-outlined text-lg" data-icon="analytics">analytics</span> Telemetry
            </a>
            <a class="flex items-center gap-3 px-6 py-3 text-slate-500 hover:bg-slate-200 transition-all font-label text-xs font-bold uppercase tracking-[0.05em]" href="#">
                <span class="material-symbols-outlined text-lg" data-icon="settings_ethernet">settings_ethernet</span> Network
            </a>
        </nav>
        <div class="px-6 mt-auto flex flex-col gap-4">
            <button class="w-full py-3 bg-tertiary text-white font-label font-bold text-xs uppercase tracking-wider rounded-lg hover:brightness-110 transition-all">
                EMERGENCY STOP
            </button>
            <div class="space-y-1 pt-4 border-t border-surface-variant/20">
                <a class="flex items-center gap-3 py-2 text-slate-500 hover:text-primary transition-colors font-label text-xs font-bold uppercase" href="#">
                    <span class="material-symbols-outlined text-lg" data-icon="help">help</span> Support
                </a>
                <a class="flex items-center gap-3 py-2 text-slate-500 hover:text-tertiary transition-colors font-label text-xs font-bold uppercase" href="#">
                    <span class="material-symbols-outlined text-lg" data-icon="logout">logout</span> Logout
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content Canvas -->
    <main class="ml-[16rem] pt-24 p-8 max-w-[1600px] mx-auto min-h-screen">
        @Body
    </main>

    <!-- Gantry Progress Rail (Custom SCADA Component) -->
    <div class="fixed bottom-0 left-[16rem] right-0 bg-surface-container-low h-1.5 z-40">
        <!-- Assume max position is 2000mm for percentage mapping, just a demo effect -->
        <div class="bg-primary h-full rounded-full transition-all duration-1000" style="width: @(Math.Min(100, Math.Max(0, (ViewModel.arr_R32.Length > 0 ? ViewModel.arr_R32[0] : 0) / 20.0)))%;"></div>
        <div class="absolute -top-6 -translate-x-1/2 flex flex-col items-center transition-all duration-1000" style="left: @(Math.Min(100, Math.Max(0, (ViewModel.arr_R32.Length > 0 ? ViewModel.arr_R32[0] : 0) / 20.0)))%;">
            <span class="text-[8px] font-bold font-label text-primary uppercase shadow-sm bg-white/50 px-1 rounded">Current Head Position</span>
            <div class="w-px h-6 bg-primary"></div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Subscribe to property changes so UI updates automatically
        ViewModel.PropertyChanged += (sender, e) => InvokeAsync(StateHasChanged);
    }
}
